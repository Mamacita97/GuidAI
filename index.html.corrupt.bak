              <div onclick="selectAudioModel('GPT-4o Voice','馃')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer flex items-center gap-2 text-[11px]"><span>馃</span><span>GPT-4o Voice</span></div>
              <div onclick="selectAudioModel('CosmicVoice','馃寣')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer flex items-center gap-2 text-[11px]"><span>馃寣</span><span>CosmicVoice</span></div>
