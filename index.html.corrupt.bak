<!-- 鈺愨晲鈺?鎿嶄綔鑿滃崟 Action Sheet 鈺愨晲鈺?-->
<div id="mob-action-sheet" style="display:none;position:fixed;inset:0;z-index:200070;background:rgba(0,0,0,0.5);align-items:flex-end;justify-content:center;" onclick="if(event.target===this)mobCloseActions()">
  <div style="width:100%;max-width:480px;background:#1a1a1a;border-radius:16px 16px 0 0;padding:8px 16px max(24px,env(safe-area-inset-bottom,24px));">
