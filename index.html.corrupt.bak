      <span style="width:28px;text-align:center;font-size:18px;">馃摛</span> 鍒嗕韩浣滃搧
    </button>

    <!-- 鍙戝竷 -->
    <button onclick="mobCloseActions();setTimeout(mobOpenPublish,150);" style="width:100%;padding:14px 0;border:none;background:transparent;color:#f3f4f6;font-size:15px;cursor:pointer;display:flex;align-items:center;gap:12px;border-bottom:1px solid #2a2a2a;text-align:left;transition:background 0.12s;" onpointerdown="this.style.background='rgba(255,255,255,0.08)'" onpointerup="this.style.background='transparent'" onpointerleave="this.style.background='transparent'">
      <span style="width:28px;text-align:center;font-size:18px;">馃殌</span> 鍙戝竷浣滃搧
    </button>

    <!-- 鍐嶆鐢熸垚 -->
