// 鈹€鈹€ 鐐硅禐/璇勮锛堟姈闊抽鏍硷級 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
window._mobLiked=false;
window.mobToggleLike=function(){
  window._mobLiked=!window._mobLiked;
  var icon=document.getElementById('mob-like-icon');
  var countEl=document.getElementById('mob-like-count');
  if(!icon||!countEl) return;
  var current=parseInt(countEl.textContent)||0;
  if(window._mobLiked){
    icon.setAttribute('fill','#ef4444');
    icon.setAttribute('stroke','#ef4444');
    countEl.textContent=current+1;
    icon.style.transition='transform 0.2s';
    icon.style.transform='scale(1.3)';
    setTimeout(function(){icon.style.transform='scale(1)';},200);
    showToast('鉂わ笍 宸茬偣璧?);
  } else {
    icon.setAttribute('fill','none');
    icon.setAttribute('stroke','#fff');
    countEl.textContent=Math.max(0,current-1);
    showToast('馃挃 宸插彇娑堢偣璧?);
  }
};
window.mobDoubleTapLike=function(e){
  mobToggleLike();
  var container=document.getElementById('mob-heart-container');
  if(!container) return;
  var rect=container.getBoundingClientRect();
  var heart=document.createElement('div');
  heart.textContent='鉂わ笍';
  heart.style.cssText='position:absolute;font-size:64px;z-index:20;pointer-events:none;left:'+(e.clientX-rect.left-32)+'px;top:'+(e.clientY-rect.top-32)+'px;opacity:1;transform:scale(0.5);transition:all 0.6s cubic-bezier(0,0,0.2,1);';
  container.appendChild(heart);
  requestAnimationFrame(function(){
    heart.style.transform='scale(1.5)';
    heart.style.opacity='0';
  });
  setTimeout(function(){heart.remove();},700);
};
window._mobCommentsInited=false;
window.mobOpenCommentSheet=function(){
  document.getElementById('mob-comment-sheet').style.display='flex';
  document.body.style.overflow='hidden';
  // 鍚屾棰勮鍥剧墖鍒拌瘎璁哄脊绐?
  var emojiEl=document.getElementById('mob-preview-emoji');
  var commentEmoji=document.getElementById('mob-comment-emoji');
  if(emojiEl&&commentEmoji) commentEmoji.textContent=emojiEl.textContent;
  var commentMedia=document.getElementById('mob-comment-media');
  var previewMedia=document.getElementById('mob-preview-media');
  if(commentMedia&&previewMedia){
    commentMedia.style.background=getComputedStyle(previewMedia).backgroundImage||getComputedStyle(previewMedia).background||'linear-gradient(135deg,#9333ea,#ec4899)';
  }
  // 棣栨鎵撳紑鐢熸垚绀轰緥璇勮
  if(!window._mobCommentsInited){
    window._mobCommentsInited=true;
    var list=document.getElementById('mob-comment-list');
    if(!list) return;
    var sampleComments=[
      {name:'闃跨鏈?,avatar:'A',color:'#6366f1',text:'鏁堟灉澶ソ浜嗭紝瀹屽叏鐪嬩笉鍑烘槸AI鐢熸垚鐨勶紒璇烽棶鐢ㄧ殑浠€涔堟ā鍨嬶紵',time:'2灏忔椂鍓?},
      {name:'闈掗潚鑽夊師',avatar:'B',color:'#10b981',text:'宸蹭娇鐢紝鏁堟灉鎯婅壋锛佷竴閿敓鎴愬お鏂逛究浜?馃敟',time:'5灏忔椂鍓?},
      {name:'璁捐鐙皬鐜?,avatar:'C',color:'#f59e0b',text:'姹傞棶鑳藉惁鏀寔鎵归噺澶勭悊锛熸湁鍑犵櫨寮犲晢鍝佸浘闇€瑕佹崲瑁?,time:'鏄ㄥぉ'},
      {name:'鏈堝厜瀹濈洅',avatar:'鏈?,color:'#8b5cf6',text:'杩欎釜閰嶈壊澶珮绾т簡锛屾眰 prompt 馃檹',time:'鏄ㄥぉ'},
      {name:'鏁扮爜灏忕帇瀛?,avatar:'馃摫',color:'#3b82f6',text:'宸茬粡鍒嗕韩缁欏洟闃熶簡锛屽ぇ瀹堕兘寰堝枩娆紒',time:'2澶╁墠'}
    ];
    sampleComments.forEach(function(c){
      var item=document.createElement('div');
      item.style.cssText='display:flex;align-items:flex-start;gap:10px;padding:10px 0;border-bottom:1px solid #1f1f1f;';
      item.innerHTML='<span style="width:30px;height:30px;border-radius:50%;background:'+c.color+';display:flex;align-items:center;justify-content:center;font-size:12px;color:#fff;font-weight:600;flex-shrink:0;">'+c.avatar+'</span><div style="flex:1;min-width:0;"><div style="display:flex;align-items:center;gap:8px;"><span style="font-weight:600;color:#e5e7eb;font-size:13px;">'+c.name+'</span><span style="color:#6b7280;font-size:11px;">'+c.time+'</span></div><div style="color:#9ca3af;font-size:13px;margin-top:3px;line-height:1.5;">'+c.text+'</div></div>';
      list.appendChild(item);
    });
  }
};
