// 鎵嬫満鐗堢鐞嗘ā寮?
window._mobManageMode=false;
window.mobToggleManage=function(){
  var btn=document.querySelector('#page-myassets-mobile .manage-btn');
  window._mobManageMode=!window._mobManageMode;
  var bar=document.getElementById('mob-batch-bar');
  if(window._mobManageMode){
    if(btn) btn.textContent='瀹屾垚';
    if(bar){bar.style.display='flex';}
    document.querySelectorAll('#page-myassets-mobile .mob-card').forEach(function(c){
      c.style.position='relative';
      if(!c.querySelector('.mob-manage-check')){
        var check=document.createElement('div');
        check.className='mob-manage-check';
        check.style.cssText='position:absolute;top:8px;right:42px;z-index:30;width:22px;height:22px;border-radius:50%;border:2px solid rgba(255,255,255,0.6);background:rgba(0,0,0,0.4);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all 0.15s;font-size:12px;color:#fff;';
        check.innerHTML='<span style="opacity:0;transition:opacity 0.15s;">鉁?/span>';
        check.dataset.checked='0';
        check.onclick=function(e){
          e.stopPropagation();
          var ch=this.querySelector('span');
          if(this.dataset.checked==='0'){
            this.dataset.checked='1';
            this.style.borderColor='#3b82f6'; this.style.background='#3b82f6';
            if(ch) ch.style.opacity='1';
          } else {
            this.dataset.checked='0';
            this.style.borderColor='rgba(255,255,255,0.6)'; this.style.background='rgba(0,0,0,0.4)';
            if(ch) ch.style.opacity='0';
          }
          mobUpdateBatchCount();
        };
        c.appendChild(check);
      }
    });
    mobUpdateBatchCount();
  } else {
    if(btn) btn.textContent='绠＄悊';
    if(bar){bar.style.display='none';}
    document.querySelectorAll('#page-myassets-mobile .mob-manage-check').forEach(function(el){el.remove();});
  }
};

// 鏇存柊鎵归噺鎿嶄綔鏍忛€変腑璁℃暟
window.mobUpdateBatchCount=function(){
  var checked=document.querySelectorAll('#page-myassets-mobile .mob-manage-check[data-checked="1"]');
  var total=document.querySelectorAll('#page-myassets-mobile .mob-card').length;
  // 鏇存柊鍏ㄩ€夊浘鏍?
  var icon=document.getElementById('mob-batch-check-icon');
  if(icon){
    if(checked.length===total&&total>0){
      icon.style.background='#3b82f6'; icon.style.borderColor='#3b82f6'; icon.textContent='鉁?;
    } else if(checked.length>0){
      icon.style.background='#3b82f6'; icon.style.borderColor='#3b82f6'; icon.textContent='-';
    } else {
      icon.style.background='transparent'; icon.style.borderColor='#6b7280'; icon.textContent='';
    }
  }
};

// 鍏ㄩ€?鍙栨秷鍏ㄩ€?
window.mobBatchSelectAll=function(){
  var allChecked=document.querySelectorAll('#page-myassets-mobile .mob-manage-check:not([data-checked="1"])');
  if(allChecked.length===0){
    // 鍏ㄩ儴宸查€変腑鈫掑彇娑堝叏閫?
    document.querySelectorAll('#page-myassets-mobile .mob-manage-check').forEach(function(c){
      c.dataset.checked='0';
      c.style.borderColor='rgba(255,255,255,0.6)'; c.style.background='rgba(0,0,0,0.4)';
      var ch=c.querySelector('span'); if(ch) ch.style.opacity='0';
    });
  } else {
    // 鍏ㄩ€?
    document.querySelectorAll('#page-myassets-mobile .mob-manage-check').forEach(function(c){
      c.dataset.checked='1';
      c.style.borderColor='#3b82f6'; c.style.background='#3b82f6';
      var ch=c.querySelector('span'); if(ch) ch.style.opacity='1';
    });
  }
  mobUpdateBatchCount();
};

// 鎵归噺鍒犻櫎
window.mobBatchDelete=function(){
  var selected=document.querySelectorAll('#page-myassets-mobile .mob-manage-check[data-checked="1"]');
  if(selected.length===0){showToast('鈿狅笍 璇峰厛閫夋嫨瑕佸垹闄ょ殑浣滃搧');return;}
  if(!confirm('纭畾瑕佸垹闄ら€変腑鐨?'+selected.length+' 涓綔鍝佸悧锛熸鎿嶄綔涓嶅彲鎾ら攢銆?)) return;
  selected.forEach(function(c){
    var card=c.closest('.mob-card');
    if(card){card.style.transition='all 0.3s';card.style.transform='scale(0.9)';card.style.opacity='0';setTimeout(function(){card.remove();},300);}
  });
  showToast('馃棏锔?宸插垹闄?'+selected.length+' 涓綔鍝?);
  setTimeout(mobUpdateBatchCount,350);
};

// 閫€鍑虹鐞嗘ā寮?
window.mobCloseManage=function(){
  if(window._mobManageMode) mobToggleManage();
};

// 鍒嗕韩闈㈡澘锛堝簳閮ㄦ粦鍏ュ姩鐢伙級
window.openMyworksShare=function(){
  var modal=document.getElementById('myworks-share-modal');
  if(!modal) return;
  var panel=document.getElementById('myworks-share-panel');
  if(panel) panel.style.transform='translateY(100%)';
  modal.style.display='flex';
  document.body.style.overflow='hidden';
  requestAnimationFrame(function(){
    requestAnimationFrame(function(){
      if(panel){
        panel.style.transition='transform 0.25s cubic-bezier(0.32,0.72,0,1)';
        panel.style.transform='translateY(0)';
      }
    });
  });
};
window.closeMyworksShare=function(){
  var panel=document.getElementById('myworks-share-panel');
  if(panel){
    panel.style.transition='transform 0.2s cubic-bezier(0.32,0.72,0,1)';
    panel.style.transform='translateY(100%)';
  }
  setTimeout(function(){
    document.getElementById('myworks-share-modal').style.display='none';
    document.body.style.overflow='';
  },200);
};

// 涓烘墜鏈哄崱鐗囨坊鍔犳潵婧愭爣璇嗗浘鏍?
function initMobSourceBadges(){
  var sourceMap={
    '鏂囩敓鍥?:'馃','鏂囩敓瑙嗛':'馃','鏂囩敓闊抽':'馃','鏂囧瓧鍒涗綔':'馃','self':'馃','褰卞儚鍒涗綔':'馃',
    '鐏垫劅骞垮満':'馃挕','inspiration':'馃挕',
    'apps':'馃幃'
  };
  document.querySelectorAll('#page-myassets-mobile .mob-card').forEach(function(card){
    var imgEl=card.querySelector('.mob-card-img');
    if(!imgEl||imgEl.querySelector('.mob-source-badge')) return;
    var src=card.getAttribute('data-source')||'';
    var icon=sourceMap[src]||'馃';
    var label=
      icon==='馃挕'?'鐏垫劅':
      icon==='馃幃'?'Apps':
      '澶фā鍨?;
    var badge=document.createElement('span');
    badge.className='mob-source-badge';
    badge.style.cssText='position:absolute;top:36px;left:8px;font-size:9px;color:#fff;background:rgba(0,0,0,0.5);padding:2px 6px;border-radius:4px;z-index:20;display:flex;align-items:center;gap:3px;';
    badge.textContent=icon+' '+label;
    imgEl.appendChild(badge);
  });
}
document.addEventListener('DOMContentLoaded',initMobSourceBadges);

// 鈫?浠ヤ笅涓哄叾浠栧姛鑳介鐣?

</script>

<!-- 鐏垫劅浣滃搧璇︽儏寮圭獥锛圧unningHub 椋庢牸锛?-->
<div id="insp-detail-modal" class="modal-overlay insp-detail-modal" onclick="if(event.target===this)closeInspirationDetail()">
  <div class="insp-detail-modal__panel" role="dialog" aria-modal="true" aria-labelledby="idm-title">
    <button type="button" class="insp-detail-modal__close" onclick="closeInspirationDetail()" aria-label="鍏抽棴">脳</button>
    <div class="insp-detail-modal__body">
      <div class="insp-detail-modal__media">
        <div id="idm-media" class="insp-detail-modal__media-inner">
          <span id="idm-media-icon" class="insp-detail-modal__media-icon" aria-hidden="true"></span>
        </div>
        <div class="insp-detail-modal__media-bar">
          <button type="button" class="insp-detail-modal__media-btn" onclick="showToast('鈻?鎾斁棰勮')">鈻?鎾斁</button>
          <button type="button" class="insp-detail-modal__media-btn" onclick="showToast('鉀?鍏ㄥ睆棰勮')">鉀?鍏ㄥ睆</button>
          <button type="button" class="insp-detail-modal__media-btn" onclick="showToast('猬?宸插紑濮嬩笅杞?)">猬?涓嬭浇</button>
        </div>
      </div>
      <div class="insp-detail-modal__side">
        <div class="insp-detail-modal__head">
          <div class="insp-detail-modal__tags">
            <span id="idm-type-tag" class="insp-detail-modal__tag">鍥剧墖</span>
            <span id="idm-price-tag" class="insp-detail-modal__tag insp-detail-modal__tag--price">鍏嶈垂</span>
          </div>
          <h2 id="idm-title" class="insp-detail-modal__title">鈥?/h2>
          <div class="insp-detail-modal__stats">
            <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg><span id="idm-views">0</span></span>
            <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg><span id="idm-likes">0</span></span>
            <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg><span id="idm-uses">0</span> 娆′娇鐢?/span>
          </div>
        </div>
        <div class="insp-detail-modal__scroll">
          <div class="insp-detail-modal__kv">
            <span class="insp-detail-modal__kv-label">浣跨敤妯″瀷</span>
            <span id="idm-model" class="insp-detail-modal__kv-value">鈥?/span>
          </div>
          <div class="insp-detail-modal__kv">
            <span class="insp-detail-modal__kv-label">浣跨敤浠锋牸</span>
            <span id="idm-price" class="insp-detail-modal__kv-value insp-detail-modal__price">鍏嶈垂</span>
          </div>
          <div class="insp-detail-modal__kv insp-detail-modal__kv--source">
            <span class="insp-detail-modal__kv-label">鏉ユ簮</span>
            <div class="insp-detail-modal__source-wrap">
              <span id="idm-source-tag" class="insp-detail-modal__source-tag" data-src="model">澶фā鍨?/span>
              <span id="idm-source-name" class="insp-detail-modal__source-name"></span>
            </div>
          </div>
          <div class="insp-detail-modal__author">
            <div id="idm-avatar" class="insp-detail-modal__avatar">馃懁</div>
            <div class="insp-detail-modal__author-meta">
              <span id="idm-author" class="insp-detail-modal__author-name">鍒涗綔鑰?/span>
              <span class="insp-detail-modal__author-sub">鍒涗綔鑰呬富椤?/span>
            </div>
            <button type="button" id="idm-follow-btn" class="insp-detail-modal__follow" onclick="toggleInspirationFollow()">+ 鍏虫敞</button>
          </div>
          <div class="insp-detail-modal__section">
            <div class="insp-detail-modal__section-title">鎻愮ず璇?/div>
            <div class="insp-detail-modal__prompt-box">
              <p id="idm-prompt" class="insp-detail-modal__prompt-text">鈥?/p>
              <div class="insp-detail-modal__prompt-actions">
                <button type="button" class="insp-detail-modal__ghost-btn" onclick="copyInspirationPrompt()">澶嶅埗</button>
                <button type="button" class="insp-detail-modal__ghost-btn" onclick="useInspirationDetail()">濉叆鍒涗綔椤?/button>
              </div>
            </div>
          </div>
          <div class="insp-detail-modal__section">
            <div class="insp-detail-modal__section-title">璇勮 <span id="idm-comment-count">0</span></div>
            <div id="idm-comment-list" class="insp-detail-modal__comment-list"></div>
            <div class="insp-detail-modal__comment-input">
              <input type="text" id="idm-comment-input" class="insp-detail-modal__comment-field" placeholder="璇寸偣浠€涔堚€? maxlength="500">
              <button type="button" class="insp-detail-modal__ghost-btn" onclick="postInspirationComment()">鍙戝竷</button>
            </div>
          </div>
        </div>
        <div class="insp-detail-modal__footer">
          <button type="button" id="idm-fav-btn" class="insp-detail-modal__icon-btn" onclick="toggleInspirationFav(this)" title="鏀惰棌">鈽?/button>
          <button type="button" class="insp-detail-modal__icon-btn" onclick="openInspirationShare()" title="鍒嗕韩">鈫?/button>
          <button type="button" id="idm-use-btn" class="insp-detail-modal__cta" onclick="useInspirationDetail()">浣跨敤杩欎釜鐏垫劅</button>
        </div>
      </div>
    </div>
  </div>
</div>

</body>
</html>
