    <div style="display:flex;gap:8px;align-items:center;">
      <input id="mob-comment-input" placeholder="璇寸偣浠€涔?.." style="flex:1;font-size:15px;border:1px solid #333;border-radius:20px;padding:10px 16px;background:#1f1f1f;color:#e5e7eb;outline:none;" onfocus="this.style.borderColor='#3b82f6'" onblur="this.style.borderColor='#333'">
      <button onclick="mobPostComment()" style="padding:10px 22px;border-radius:20px;border:none;background:#3b82f6;color:#fff;font-size:14px;cursor:pointer;font-weight:600;white-space:nowrap;">鍙戦€?/button>
