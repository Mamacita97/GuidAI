              <input type="range" id="video-duration-slider" class="video-duration-slider flex-1" min="2" max="16" step="1" value="4" oninput="setVideoDuration(this.value)">
              <span id="video-duration-display" class="text-[11px] text-gray-300 bg-[#2a2a2a] border border-gray-600 rounded px-2 py-0.5 min-w-[40px] text-center">4绉?/span>
            </div>
          </div>
          <div class="px-3 py-2 pb-3">
            <div class="vop-section-title">鐢熸垚闊抽</div>
