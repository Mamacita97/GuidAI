          <span class="app-image-ws-action-icon" aria-hidden="true">馃挰</span>
          <span id="aiws-comment-count">0</span>
        </button>
        <button type="button" class="app-image-ws-close" onclick="closeModal('app-image-workspace-modal')" aria-label="鍏抽棴">脳</button>
      </div>
    </header>

    <div class="app-image-ws-body aiws-history-open">
      <aside class="app-image-ws-params">
        <div class="app-image-ws-params-scroll">
          <div class="app-image-ws-side-panel" data-aiws-panel="params">
            <h1 class="app-image-ws-title" id="aiws-title">搴旂敤鍚嶇О</h1>
            <div class="app-image-ws-tags" id="aiws-tags"></div>
