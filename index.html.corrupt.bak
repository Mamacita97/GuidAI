    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="p-4 bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 border border-blue-100 dark:border-blue-800 rounded-xl text-center">
        <div class="text-2xl mb-1">馃實</div>
        <div class="text-xs font-medium">AI for Everyone</div>
        <div class="text-[10px] text-gray-400 mt-0.5">AI鎶€鏈櫘鎯犲寲</div>
      </div>
      <div class="p-4 bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 border border-green-100 dark:border-green-800 rounded-xl text-center">
        <div class="text-2xl mb-1">馃帹</div>
