            <div onclick="selectVideoModel('Sora2','馃幀')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer"><div class="flex items-center gap-2"><span>馃幀</span><span class="text-[11px]">Sora2</span></div></div>
            <div onclick="selectVideoModel('Kling 2.0','鈿?)" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer"><div class="flex items-center gap-2"><span>鈿?/span><span class="text-[11px]">Kling 2.0</span></div></div>
            <div onclick="selectVideoModel('Runway Gen-4','馃殌')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer"><div class="flex items-center gap-2"><span>馃殌</span><span class="text-[11px]">Runway Gen-4</span></div></div>
            <div onclick="selectVideoModel('Pika 3.0','馃帹')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer"><div class="flex items-center gap-2"><span>馃帹</span><span class="text-[11px]">Pika 3.0</span></div></div>
            <div onclick="selectVideoModel('VIDU-闊充箰MV','馃幍')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer"><div class="flex items-center gap-2"><span>馃幍</span><span class="text-[11px]">VIDU-闊充箰MV</span></div></div>
