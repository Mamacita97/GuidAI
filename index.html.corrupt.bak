  .myworks-card-check {
    position: absolute;
    top: 6px; left: 6px;
    z-index: 15;
    width: 22px; height: 22px;
    border-radius: 50%;
    background: rgba(255,255,255,0.85);
    border: 2px solid #d1d5db;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.15s;
    opacity: 0;
    pointer-events: none;
  }
  .masonry-card.manage-show .myworks-card-check {
    opacity: 1;
    pointer-events: auto;
  }
  .masonry-card.selected .myworks-card-check {
    background: #3b82f6;
    border-color: #3b82f6;
  }
  .masonry-card.selected .myworks-card-check svg {
    stroke: #fff;
  }
  .myworks-card-check svg {
    display: block;
    width: 12px; height: 12px;
    stroke: transparent;
  }
  .masonry-card.selected {
    outline: 2px solid #3b82f6;
    outline-offset: 2px;
    border-radius: 12px;
  }
  .masonry-card {
    transition: outline 0.15s, opacity 0.15s;
  }
  .masonry-card.manage-show {
    cursor: pointer;
  }
</style>


