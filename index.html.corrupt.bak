      <span style="width:28px;text-align:center;font-size:18px;">馃攧</span> 鍐嶆鐢熸垚
    </button>

    <!-- 涓嬭浇 -->
    <button onclick="showToast('馃摜 涓嬭浇');mobCloseActions();" style="width:100%;padding:14px 0;border:none;background:transparent;color:#f3f4f6;font-size:15px;cursor:pointer;display:flex;align-items:center;gap:12px;border-bottom:1px solid #2a2a2a;text-align:left;transition:background 0.12s;" onpointerdown="this.style.background='rgba(255,255,255,0.08)'" onpointerup="this.style.background='transparent'" onpointerleave="this.style.background='transparent'">
      <span style="width:28px;text-align:center;font-size:18px;">猬囷笍</span> 涓嬭浇
    </button>

    <!-- 鍒犻櫎 -->
    <button onclick="var c=mobGetActionCard();if(c)deleteProduct({closest:function(){return c}});mobCloseActions();" style="width:100%;padding:14px 0;border:none;background:transparent;color:#ef4444;font-size:15px;cursor:pointer;display:flex;align-items:center;gap:12px;text-align:left;transition:background 0.12s;" onpointerdown="this.style.background='rgba(239,68,68,0.12)'" onpointerup="this.style.background='transparent'" onpointerleave="this.style.background='transparent'">
      <span style="width:28px;text-align:center;font-size:18px;">馃棏锔?/span> 鍒犻櫎
    </button>

    <!-- 鍙栨秷 -->
