window.mobPostComment=function(){
  var input=document.getElementById('mob-comment-input');
  if(!input||!input.value.trim()){showToast('鈿狅笍 璇疯緭鍏ヨ瘎璁哄唴瀹?);return;}
  var text=input.value.trim();
  input.value='';
  var list=document.getElementById('mob-comment-list');
  if(list){
    var item=document.createElement('div');
    item.style.cssText='display:flex;align-items:flex-start;gap:10px;padding:8px 0;border-bottom:1px solid #2a2a2a;font-size:13px;';
    item.innerHTML='<span style="color:#3b82f6;font-weight:600;flex-shrink:0;width:28px;height:28px;border-radius:50%;background:rgba(59,130,246,0.15);display:flex;align-items:center;justify-content:center;font-size:12px;">鎴?/span><div style="flex:1;min-width:0;"><div style="font-weight:600;color:#f3f4f6;font-size:12px;">鎴?/div><div style="color:#d1d5db;margin-top:2px;">'+text+'</div></div><span style="color:#6b7280;font-size:11px;flex-shrink:0;">鍒氬垰</span>';
    list.appendChild(item);
    list.scrollTop=list.scrollHeight;
  }
  showToast('馃挰 璇勮宸插彂閫?);
};

