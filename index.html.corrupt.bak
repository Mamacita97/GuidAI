        </div>
        <span id="audio-gen-cost" class="text-[11px] font-medium px-2 py-1 bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-lg border border-blue-100 dark:border-blue-800 shrink-0 whitespace-nowrap inline-flex items-center gap-0.5">馃挵 鏈: <span class="text-yellow-500 leading-none" aria-hidden="true">鈿?/span>0.0020</span>
        <div class="flex-1 min-w-[8px]"></div>
        <button type="button" id="audio-gen-btn-desktop" onclick="startAudioGeneration()" class="gen-btn px-4 py-1 bg-gradient-to-r from-blue-500 to-purple-600 text-white text-xs font-semibold rounded-lg hover:from-blue-600 hover:to-purple-700 transition shrink-0">鉁?鐢熸垚</button>
        </div>
      </div>
    </div>
