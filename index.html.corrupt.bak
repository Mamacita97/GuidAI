    @media (max-width: 768px) {
      #fav-apps-preview-modal > div:last-child { flex-direction:column !important; }
      #fav-apps-preview-modal > div:last-child > div:first-child { width:100% !important; min-width:0 !important; max-height:40vh !important; overflow-y:auto !important; }
    }
  </style>

  <!-- 鈹€鈹€ 椤堕儴鏍囬鏍?鈹€鈹€ -->
  <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 20px;background:#1a1a1a;border-bottom:1px solid #2a2a2a;flex-shrink:0;">
    <!-- 宸︿晶锛氭爣棰?+ 鏍囩 -->
    <div style="display:flex;align-items:center;gap:12px;min-width:0;flex:1;">
      <h2 id="fapm-title" style="font-size:15px;font-weight:700;color:#f9fafb;margin:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:360px;">App鍚嶇О</h2>
      <div id="fapm-tags" style="display:flex;gap:6px;flex-wrap:nowrap;"></div>
    </div>
    <!-- 鍙充晶锛氭暟鎹?+ 鍏抽棴 -->
    <div style="display:flex;align-items:center;gap:16px;flex-shrink:0;">
      <!-- 鐐硅禐鎸夐挳 -->
      <button id="fapm-like-btn" onclick="fapmToggleLike()" style="display:flex;align-items:center;gap:5px;font-size:12px;color:#9ca3af;border:none;background:transparent;cursor:pointer;padding:2px;">
        <svg id="fapm-like-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        <span id="fapm-likes">0</span>
      </button>
      <!-- 鏀惰棌鎸夐挳 -->
      <button id="fapm-fav-btn" onclick="fapmToggleFav()" style="display:flex;align-items:center;gap:5px;font-size:12px;color:#f59e0b;border:none;background:transparent;cursor:pointer;padding:2px;">
        <svg id="fapm-fav-icon" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <span id="fapm-fav-count" style="font-size:12px;color:#f59e0b;">0</span>
      </button>
      <button onclick="closeFavAppsPreview()" style="width:28px;height:28px;border-radius:50%;border:none;background:rgba(255,255,255,0.1);cursor:pointer;display:flex;align-items:center;justify-content:center;color:#d1d5db;font-size:16px;line-height:1;transition:background 0.15s;" onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'">脳</button>
    </div>
  </div>

  <!-- 鈹€鈹€ 涓讳綋鍖哄煙锛堝乏渚ц竟鏍?+ 涓棿鍐呭锛?鈹€鈹€ -->
  <div style="flex:1;display:flex;flex-direction:row;overflow:hidden;min-height:0;">

    <!-- 宸︿晶杈规爮锛堟殫鑹诧紝鍥哄畾瀹藉害锛?-->
    <div style="width:260px;min-width:260px;background:#1a1a1a;border-right:1px solid #2a2a2a;display:flex;flex-direction:column;overflow-y:auto;">

      <!-- 鍒涗綔鑰呬俊鎭?-->
      <div style="padding:14px 16px 10px;border-bottom:1px solid #252525;">
        <div style="font-size:11px;color:#6b7280;margin-bottom:8px;font-weight:500;">鍒涗綔灏忚创澹?/div>
        <div style="font-size:11px;color:#10b981;margin-bottom:3px;">鈼?杩戞湡杩愯鎴愬姛鐜囦负<span id="fapm-success-rate">98%</span></div>
        <div style="font-size:11px;color:#f59e0b;">鈿?骞冲潎杩愯鏃堕暱绾?span id="fapm-avg-time">34s</span>宸﹀彸</div>
      </div>

      <!-- 鍒涗綔鑰呭ご鍍?+ 鍚嶇О -->
      <div style="padding:12px 16px;border-bottom:1px solid #252525;display:flex;align-items:center;justify-content:space-between;">
        <div style="display:flex;align-items:center;gap:8px;">
          <div id="fapm-avatar-wrap" style="width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,#f59e0b,#ef4444);display:flex;align-items:center;justify-content:center;font-size:14px;overflow:hidden;flex-shrink:0;">
            <img id="fapm-avatar-img" src="" alt="" style="width:100%;height:100%;object-fit:cover;display:none;">
            <span id="fapm-avatar-fallback">馃</span>
          </div>
          <div>
            <div id="fapm-author" style="font-size:12px;font-weight:600;color:#f3f4f6;">鍒涗綔鑰?/div>
            <div id="fapm-updated" style="font-size:10px;color:#6b7280;"></div>
          </div>
        </div>
        <button id="fapm-follow-btn" onclick="fapmToggleFollow()" style="padding:4px 10px;border-radius:12px;border:1px solid #374151;background:transparent;color:#9ca3af;font-size:11px;cursor:pointer;">+ 鍏虫敞</button>
      </div>

      <!-- 妯＄壒鍥句笂浼犲尯 -->
      <div style="padding:12px 16px;border-bottom:1px solid #252525;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
          <span style="font-size:11px;font-weight:600;color:#d1d5db;">妯＄壒鍥?/span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2"><polyline points="18 15 12 9 6 15"/></svg>
        </div>
        <div onclick="openAssetModal('image')" style="border:1.5px dashed #374151;border-radius:10px;overflow:hidden;position:relative;cursor:pointer;">
          <div style="background:linear-gradient(135deg,#b45309,#92400e);aspect-ratio:1;display:flex;align-items:center;justify-content:center;font-size:32px;">馃Д</div>
          <button onclick="event.stopPropagation();openAssetModal('image')" style="position:absolute;bottom:6px;right:6px;width:22px;height:22px;border-radius:6px;border:none;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;cursor:pointer;">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </button>
        </div>
      </div>

      <!-- 鏇挎崲琛ｇ墿鍥句笂浼犲尯 -->
      <div style="padding:12px 16px;border-bottom:1px solid #252525;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
          <span style="font-size:11px;font-weight:600;color:#d1d5db;">鏇挎崲琛ｇ墿鍥?/span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2"><polyline points="18 15 12 9 6 15"/></svg>
        </div>
        <div onclick="openAssetModal('image')" style="border:1.5px dashed #374151;border-radius:10px;overflow:hidden;position:relative;cursor:pointer;">
          <div style="background:linear-gradient(135deg,#1e3a5f,#1e40af);aspect-ratio:1;display:flex;align-items:center;justify-content:center;font-size:32px;">馃憯</div>
          <button onclick="event.stopPropagation();openAssetModal('image')" style="position:absolute;bottom:6px;right:6px;width:22px;height:22px;border-radius:6px;border:none;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:pointer;">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </button>
        </div>
      </div>

      <!-- 鎻愮ず璇?-->
      <div style="padding:12px 16px;border-bottom:1px solid #252525;flex:1;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
          <span style="font-size:11px;font-weight:600;color:#d1d5db;">鎻愮ず璇?/span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2"><polyline points="18 15 12 9 6 15"/></svg>
        </div>
        <textarea placeholder="璁╁浘涓€鐨勪汉鐗╃┛涓婂浘浜岀殑琛ｆ湇" style="width:100%;height:80px;background:#252525;border:1px solid #374151;border-radius:8px;color:#d1d5db;font-size:11px;padding:8px;resize:none;box-sizing:border-box;outline:none;font-family:inherit;" oninput="this.style.borderColor='#3b82f6'" onblur="this.style.borderColor='#374151'"></textarea>
      </div>

      <!-- 搴曢儴杩愯鎸夐挳 -->
      <div style="padding:12px 16px;flex-shrink:0;">
        <button onclick="showToast('鈿?姝ｅ湪杩愯搴旂敤...')" style="width:100%;padding:10px 0;border-radius:10px;border:none;background:linear-gradient(90deg,#10b981,#06b6d4);color:#fff;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;transition:opacity 0.15s;" onmouseover="this.style.opacity='0.88'" onmouseout="this.style.opacity='1'">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><polygon points="5,3 19,12 5,21"/></svg>
          <span>R<span id="fapm-price-val">7</span></span>

        </button>
      </div>
    </div>

    <!-- 涓棿涓诲尯鍩?-->
    <div style="flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0;background:#111;">

      <!-- 搴旂敤浠嬬粛锛堝彲鎶樺彔锛?-->
      <div id="fapm-intro-box" style="background:#1e1e1e;border-bottom:1px solid #2a2a2a;flex-shrink:0;">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;padding:10px 20px 8px;gap:12px;">
          <div style="flex:1;min-width:0;">
            <div style="font-size:11px;color:#6b7280;margin-bottom:4px;">搴旂敤浠嬬粛&amp;杈撳叆寤鸿</div>
            <div id="fapm-desc" style="font-size:12px;color:#d1d5db;line-height:1.6;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden;">搴旂敤鎻忚堪</div>
          </div>
          <button onclick="toggleFapmIntro()" style="flex-shrink:0;width:24px;height:24px;border:none;background:transparent;cursor:pointer;color:#6b7280;display:flex;align-items:center;justify-content:center;margin-top:16px;">
            <svg id="fapm-intro-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="18 15 12 9 6 15"/></svg>
          </button>
        </div>
      </div>

      <!-- 澶у浘灞曠ず鍖猴紙涓績锛?-->
      <div style="flex:1;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;padding:20px;">
        <!-- 缈婚〉宸︾澶?-->
        <button onclick="fapmPrev()" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);width:32px;height:32px;border-radius:50%;border:none;background:rgba(255,255,255,0.1);cursor:pointer;display:flex;align-items:center;justify-content:center;color:#fff;z-index:5;" onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <!-- 涓诲浘 -->
        <div id="fapm-main-img-box" style="max-width:420px;width:100%;border-radius:12px;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,0.6);background:linear-gradient(135deg,#1e3a5f,#1e40af);aspect-ratio:3/4;display:flex;align-items:center;justify-content:center;position:relative;">
          <img id="fapm-main-img" src="" alt="" style="width:100%;height:100%;object-fit:cover;display:none;">
          <span id="fapm-main-emoji" style="font-size:72px;">馃憲</span>
          <!-- 椤电爜 -->
          <div id="fapm-page-indicator" style="position:absolute;bottom:10px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.6);color:#fff;font-size:10px;padding:3px 10px;border-radius:10px;backdrop-filter:blur(4px);">1/4</div>
        </div>
        <!-- 缈婚〉鍙崇澶?-->
        <button onclick="fapmNext()" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);width:32px;height:32px;border-radius:50%;border:none;background:rgba(255,255,255,0.1);cursor:pointer;display:flex;align-items:center;justify-content:center;color:#fff;z-index:5;" onmouseover="this.style.background='rgba(255,255,255,0.2)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>

      <!-- 搴曢儴锛氫綔鍝?璇勮Tab + 浣滃搧缃戞牸 -->
      <div style="background:#111;border-top:1px solid #2a2a2a;flex-shrink:0;max-height:220px;display:flex;flex-direction:column;">
        <!-- Tab + 鍙戝竷浣滃搧鎸夐挳 -->
        <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 20px 0;flex-shrink:0;">
          <div style="display:flex;gap:0;">
            <button id="fapm-works-tab-btn" onclick="switchFapmTab('works')" style="padding:6px 12px;border:none;background:transparent;color:#f9fafb;font-size:13px;font-weight:600;cursor:pointer;border-bottom:2px solid #3b82f6;">浣滃搧 (<span id="fapm-works-count">7</span>)</button>
            <button id="fapm-comments-tab-btn" onclick="switchFapmTab('comments')" style="padding:6px 12px;border:none;background:transparent;color:#6b7280;font-size:13px;cursor:pointer;border-bottom:2px solid transparent;">璇勮 (<span id="fapm-comments-count">14</span>)</button>
          </div>
          <button onclick="fapmPublishWork()" style="padding:6px 16px;border-radius:20px;border:none;background:#10b981;color:#fff;font-size:12px;font-weight:600;cursor:pointer;">鍙戝竷浣滃搧</button>
        </div>
        <!-- 浣滃搧缃戞牸 -->
        <div id="fapm-works-grid" style="flex:1;overflow-x:auto;overflow-y:hidden;padding:10px 20px;display:flex;gap:8px;">
          <div style="width:110px;min-width:110px;height:110px;border-radius:8px;overflow:hidden;background:linear-gradient(135deg,#374151,#1f2937);display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0;cursor:pointer;" onclick="showToast('馃憖 鏌ョ湅浣滃搧')">馃鈥嶐煢?/div>
          <div style="width:110px;min-width:110px;height:110px;border-radius:8px;overflow:hidden;background:linear-gradient(135deg,#374151,#1f2937);display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0;cursor:pointer;" onclick="showToast('馃憖 鏌ョ湅浣滃搧')">馃懇</div>
          <div style="width:110px;min-width:110px;height:110px;border-radius:8px;overflow:hidden;background:linear-gradient(135deg,#374151,#1f2937);display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0;cursor:pointer;" onclick="showToast('馃憖 鏌ョ湅浣滃搧')">馃Д</div>
          <div style="width:110px;min-width:110px;height:110px;border-radius:8px;overflow:hidden;background:linear-gradient(135deg,#374151,#1f2937);display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0;cursor:pointer;" onclick="showToast('馃憖 鏌ョ湅浣滃搧')">馃憲</div>
          <div style="width:110px;min-width:110px;height:110px;border-radius:8px;overflow:hidden;background:linear-gradient(135deg,#374151,#1f2937);display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0;cursor:pointer;" onclick="showToast('馃憖 鏌ョ湅浣滃搧')">馃В</div>
          <div style="width:110px;min-width:110px;height:110px;border-radius:8px;overflow:hidden;background:linear-gradient(135deg,#374151,#1f2937);display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0;cursor:pointer;" onclick="showToast('馃憖 鏌ョ湅浣滃搧')">馃憯</div>
          <div style="width:110px;min-width:110px;height:110px;border-radius:8px;overflow:hidden;background:linear-gradient(135deg,#374151,#1f2937);display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0;cursor:pointer;" onclick="showToast('馃憖 鏌ョ湅浣滃搧')">馃巰</div>
        </div>
        <!-- 璇勮鍖?-->
        <div id="fapm-comments-section" style="flex:1;overflow-y:auto;padding:10px 20px;display:none;">
          <div style="display:flex;gap:10px;margin-bottom:14px;">
            <div style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,#6366f1,#8b5cf6);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:12px;color:#fff;font-weight:600;">A</div>
            <div style="flex:1;min-width:0;">
              <div style="display:flex;align-items:baseline;gap:8px;"><span style="font-size:12px;font-weight:600;color:#f3f4f6;">闃跨鏈?/span><span style="font-size:10px;color:#6b7280;">2灏忔椂鍓?/span></div>
              <div style="font-size:11px;color:#d1d5db;margin-top:2px;line-height:1.5;">鏁堟灉澶ソ浜嗭紝瀹屽叏鐪嬩笉鍑烘槸AI鐢熸垚鐨勶紒璇烽棶鐢ㄧ殑浠€涔堟ā鍨嬶紵</div>
              <div style="display:flex;gap:12px;margin-top:4px;"><button onclick="showToast('鉂わ笍 鐐硅禐')" style="font-size:10px;color:#6b7280;border:none;background:transparent;cursor:pointer;padding:0;">馃憤 12</button><button onclick="showToast('馃挰 鍥炲')" style="font-size:10px;color:#6b7280;border:none;background:transparent;cursor:pointer;padding:0;">鍥炲</button></div>
            </div>
          </div>
          <div style="display:flex;gap:10px;margin-bottom:14px;">
            <div style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,#10b981,#059669);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:12px;color:#fff;font-weight:600;">B</div>
            <div style="flex:1;min-width:0;">
              <div style="display:flex;align-items:baseline;gap:8px;"><span style="font-size:12px;font-weight:600;color:#f3f4f6;">闈掗潚鑽夊師</span><span style="font-size:10px;color:#6b7280;">5灏忔椂鍓?/span></div>
              <div style="font-size:11px;color:#d1d5db;margin-top:2px;line-height:1.5;">宸蹭娇鐢紝鏁堟灉鎯婅壋锛佷竴閿敓鎴愬お鏂逛究浜?/div>
              <div style="display:flex;gap:12px;margin-top:4px;"><button onclick="showToast('鉂わ笍 鐐硅禐')" style="font-size:10px;color:#6b7280;border:none;background:transparent;cursor:pointer;padding:0;">馃憤 5</button><button onclick="showToast('馃挰 鍥炲')" style="font-size:10px;color:#6b7280;border:none;background:transparent;cursor:pointer;padding:0;">鍥炲</button></div>
            </div>
          </div>
          <div style="display:flex;gap:10px;margin-bottom:14px;">
            <div style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,#f59e0b,#ef4444);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:12px;color:#fff;font-weight:600;">C</div>
            <div style="flex:1;min-width:0;">
              <div style="display:flex;align-items:baseline;gap:8px;"><span style="font-size:12px;font-weight:600;color:#f3f4f6;">璁捐鐙皬鐜?/span><span style="font-size:10px;color:#6b7280;">鏄ㄥぉ</span></div>
              <div style="font-size:11px;color:#d1d5db;margin-top:2px;line-height:1.5;">姹傞棶鑳藉惁鏀寔鎵归噺澶勭悊锛熸湁鍑犵櫨寮犲晢鍝佸浘闇€瑕佹崲瑁?/div>
              <div style="display:flex;gap:12px;margin-top:4px;"><button onclick="showToast('鉂わ笍 鐐硅禐')" style="font-size:10px;color:#6b7280;border:none;background:transparent;cursor:pointer;padding:0;">馃憤 3</button><button onclick="showToast('馃挰 鍥炲')" style="font-size:10px;color:#6b7280;border:none;background:transparent;cursor:pointer;padding:0;">鍥炲</button></div>
            </div>
          </div>
        </div>
