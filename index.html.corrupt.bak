<script>
window.mwpToggleComment=function(){
  var body=document.getElementById('mwp-comment-body');
  var arrow=document.getElementById('mwp-comment-arrow');
  if(!body) return;
  if(body.dataset.open==='1'){
    body.style.maxHeight='0';
    body.dataset.open='0';
    if(arrow) arrow.style.transform='rotate(0deg)';
  } else {
    body.style.maxHeight=body.scrollHeight+'px';
    body.dataset.open='1';
    if(arrow) arrow.style.transform='rotate(180deg)';
  }
};
document.addEventListener('DOMContentLoaded',function(){
  var body=document.getElementById('mwp-comment-body');
  if(body){body.style.maxHeight='0';body.dataset.open='0';}
});
</script>

<!-- 鈺愨晲鈺愨晲鈺愨晲鈺?鏀惰棌Apps棰勮寮圭獥 鈺愨晲鈺愨晲鈺愨晲鈺?-->
