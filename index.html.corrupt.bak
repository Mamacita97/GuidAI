      <!-- 杈撳嚭鍙傛暟锛堟潯鏁?/ 娓呮櫚搴?/ 姣斾緥锛?-->
      <div class="relative shrink-0" id="video-output-params-wrap">
        <button type="button" onclick="toggleVideoOutputParamsDropdown(event)" class="text-[10px] px-2.5 py-1 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700/50 hover:bg-gray-100 dark:hover:bg-gray-600 transition flex items-center gap-1.5 text-gray-700 dark:text-gray-200">
          <svg class="shrink-0 text-gray-500 dark:text-gray-400" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
          <span id="video-output-params-label" class="whitespace-nowrap">1:1 / 480p / 4绉?/ 鏃犻厤闊?/span>
          <svg class="shrink-0 text-gray-400" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div id="video-output-params-dropdown" class="hidden absolute bottom-full left-0 mb-1 w-[300px] video-output-panel shadow-2xl overflow-hidden z-50 max-h-[70vh] overflow-y-auto">
          <div class="px-3 pt-3 pb-2 border-b border-gray-700/80">
            <div class="vop-section-title">瑙嗛姣斾緥</div>
            <div class="grid grid-cols-7 gap-1">
              <button type="button" onclick="setVideoOutputParam('ratio','Auto')" data-vparam="ratio" data-vvalue="Auto" class="video-ratio-opt flex flex-col items-center gap-0.5 py-1.5 text-[9px]"><span class="w-4 h-3 border border-current rounded-[2px] opacity-70"></span>Auto</button>
              <button type="button" onclick="setVideoOutputParam('ratio','16:9')" data-vparam="ratio" data-vvalue="16:9" class="video-ratio-opt flex flex-col items-center gap-0.5 py-1.5 text-[9px]"><span class="w-5 h-2.5 border border-current rounded-[2px]"></span>16:9</button>
              <button type="button" onclick="setVideoOutputParam('ratio','4:3')" data-vparam="ratio" data-vvalue="4:3" class="video-ratio-opt flex flex-col items-center gap-0.5 py-1.5 text-[9px]"><span class="w-4 h-3 border border-current rounded-[2px]"></span>4:3</button>
              <button type="button" onclick="setVideoOutputParam('ratio','1:1')" data-vparam="ratio" data-vvalue="1:1" class="video-ratio-opt flex flex-col items-center gap-0.5 py-1.5 text-[9px]"><span class="w-3.5 h-3.5 border border-current rounded-[2px]"></span>1:1</button>
              <button type="button" onclick="setVideoOutputParam('ratio','3:4')" data-vparam="ratio" data-vvalue="3:4" class="video-ratio-opt flex flex-col items-center gap-0.5 py-1.5 text-[9px]"><span class="w-3 h-4 border border-current rounded-[2px]"></span>3:4</button>
              <button type="button" onclick="setVideoOutputParam('ratio','9:16')" data-vparam="ratio" data-vvalue="9:16" class="video-ratio-opt flex flex-col items-center gap-0.5 py-1.5 text-[9px]"><span class="w-2.5 h-5 border border-current rounded-[2px]"></span>9:16</button>
              <button type="button" onclick="setVideoOutputParam('ratio','21:9')" data-vparam="ratio" data-vvalue="21:9" class="video-ratio-opt flex flex-col items-center gap-0.5 py-1.5 text-[9px]"><span class="w-6 h-2 border border-current rounded-[2px]"></span>21:9</button>
            </div>
          </div>
          <div class="px-3 py-2 border-b border-gray-700/80">
            <div class="vop-section-title">瑙嗛璐ㄩ噺</div>
            <div class="grid grid-cols-3 gap-1.5">
              <button type="button" onclick="setVideoOutputParam('quality','480p')" data-vparam="quality" data-vvalue="480p" class="video-quality-opt text-[10px] py-1.5">480p</button>
              <button type="button" onclick="setVideoOutputParam('quality','720p')" data-vparam="quality" data-vvalue="720p" class="video-quality-opt text-[10px] py-1.5">720p</button>
              <button type="button" onclick="setVideoOutputParam('quality','native1080p')" data-vparam="quality" data-vvalue="native1080p" class="video-quality-opt text-[10px] py-1.5">native1080p</button>
              <button type="button" onclick="setVideoOutputParam('quality','1080p')" data-vparam="quality" data-vvalue="1080p" class="video-quality-opt text-[10px] py-1.5">1080p</button>
              <button type="button" onclick="setVideoOutputParam('quality','2k')" data-vparam="quality" data-vvalue="2k" class="video-quality-opt text-[10px] py-1.5">2k</button>
              <button type="button" onclick="setVideoOutputParam('quality','4k')" data-vparam="quality" data-vvalue="4k" class="video-quality-opt text-[10px] py-1.5">4k</button>
            </div>
          </div>
          <div class="px-3 py-2 border-b border-gray-700/80">
            <div class="vop-section-title">瑙嗛鏃堕暱</div>
