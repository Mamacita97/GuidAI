        </button>
        <div id="video-role-dropdown" class="hidden absolute bottom-full left-0 mb-1 w-48 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-lg overflow-hidden z-50">
          <div class="px-3 py-2 text-[10px] text-gray-400 border-b border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">鉁?鎻愮ず璇嶄紭鍖?/div>
          <div class="py-1 max-h-48 overflow-y-auto">
            <div onclick="openVideoPromptOptimizeModal(event,'鐭棰戠紪瀵?)" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer"><div class="flex items-center gap-2"><span>馃摫</span><span class="text-[11px]">鐭棰戠紪瀵?/span></div></div>
            <div onclick="openVideoPromptOptimizeModal(event,'骞垮憡瀵兼紨')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer"><div class="flex items-center gap-2"><span>馃摵</span><span class="text-[11px]">骞垮憡瀵兼紨</span></div></div>
            <div onclick="openVideoPromptOptimizeModal(event,'寰數褰卞婕?)" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer"><div class="flex items-center gap-2"><span>馃帴</span><span class="text-[11px]">寰數褰卞婕?/span></div></div>
            <div onclick="openVideoPromptOptimizeModal(event,'MV瀵兼紨')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer"><div class="flex items-center gap-2"><span>馃帳</span><span class="text-[11px]">MV瀵兼紨</span></div></div>
            <div onclick="openVideoPromptOptimizeModal(event,'绾綍鐗囩紪瀵?)" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer"><div class="flex items-center gap-2"><span>馃摻锔?/span><span class="text-[11px]">绾綍鐗囩紪瀵?/span></div></div>
