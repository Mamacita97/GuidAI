        <div class="relative shrink-0" id="audio-output-params-wrap">
          <button type="button" onclick="toggleAudioOutputParamsDropdown()" class="text-[10px] px-2.5 py-1 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700/50 hover:bg-gray-100 dark:hover:bg-gray-600 transition flex items-center gap-1.5 text-gray-700 dark:text-gray-200">
            <svg class="shrink-0 text-gray-500 dark:text-gray-400" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>
            <span id="audio-output-params-label" class="whitespace-nowrap">1.0x / 鏍囧噯 / 鏃?/span>
            <svg class="shrink-0 text-gray-400" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div id="audio-output-params-dropdown" class="hidden absolute bottom-full left-0 mb-1 w-[280px] output-params-panel shadow-2xl overflow-hidden z-50">
            <div class="px-3 pt-3 pb-2 border-b border-gray-700/80">
              <div class="vop-section-title">璇€?/div>
              <div class="flex">
                <button type="button" onclick="setAudioOutputParam('speed','1.0x')" data-aparam="speed" data-avalue="1.0x" class="param-seg-opt">1.0x</button>
                <button type="button" onclick="setAudioOutputParam('speed','0.5x')" data-aparam="speed" data-avalue="0.5x" class="param-seg-opt">0.5x</button>
                <button type="button" onclick="setAudioOutputParam('speed','2.0x')" data-aparam="speed" data-avalue="2.0x" class="param-seg-opt">2.0x</button>
              </div>
            </div>
            <div class="px-3 py-2 border-b border-gray-700/80">
              <div class="vop-section-title">璇皟</div>
              <div class="flex">
                <button type="button" onclick="setAudioOutputParam('tone','鏍囧噯')" data-aparam="tone" data-avalue="鏍囧噯" class="param-seg-opt">鏍囧噯</button>
                <button type="button" onclick="setAudioOutputParam('tone','鏌斿拰')" data-aparam="tone" data-avalue="鏌斿拰" class="param-seg-opt">鏌斿拰</button>
                <button type="button" onclick="setAudioOutputParam('tone','婵€鏄?)" data-aparam="tone" data-avalue="婵€鏄? class="param-seg-opt">婵€鏄?/button>
              </div>
            </div>
            <div class="px-3 py-2 pb-3">
              <div class="vop-section-title">闊虫晥</div>
              <div class="flex">
                <button type="button" onclick="setAudioOutputParam('effect','鏃?)" data-aparam="effect" data-avalue="鏃? class="param-seg-opt">鏃?/button>
                <button type="button" onclick="setAudioOutputParam('effect','鍥炲０')" data-aparam="effect" data-avalue="鍥炲０" class="param-seg-opt">鍥炲０</button>
                <button type="button" onclick="setAudioOutputParam('effect','娣峰搷')" data-aparam="effect" data-avalue="娣峰搷" class="param-seg-opt">娣峰搷</button>
              </div>
            </div>
          </div>
          <input type="hidden" id="audio-param-speed" value="1.0x">
          <input type="hidden" id="audio-param-tone" value="鏍囧噯">
          <input type="hidden" id="audio-param-effect" value="鏃?>
        </div>
        <select id="audio-param-quality" onchange="typeof updateAudioGenCost==='function'&&updateAudioGenCost()" class="text-[10px] border border-gray-200 dark:border-gray-600 rounded-lg px-2 py-1 bg-white dark:bg-gray-800 outline-none shrink-0"><option value="Turbo">璐ㄩ噺 Turbo</option><option value="鏍囧噯">璐ㄩ噺 鏍囧噯</option><option value="楂樻竻">璐ㄩ噺 楂樻竻</option></select>
        <div class="relative shrink-0" id="audio-emotion-wrap">
          <button type="button" id="audio-emotion-btn" onclick="toggleAudioEmotionPicker(event)" class="audio-emotion-btn" title="閫夋嫨鎯呯华" aria-expanded="false" aria-haspopup="listbox">
