          <span id="aiws-like-count">0</span>
        </button>
        <button type="button" class="app-image-ws-action" id="aiws-fav-btn" onclick="toggleAiwsFav()" aria-pressed="false">
          <span class="app-image-ws-action-icon" aria-hidden="true">鈽?/span>
