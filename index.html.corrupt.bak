    <button onclick="showToast('馃摜 鎵归噺涓嬭浇');mobCloseManage()" style="display:flex;align-items:center;gap:4px;border:none;background:#374151;color:#f3f4f6;font-size:12px;cursor:pointer;padding:8px 16px;border-radius:8px;transition:background 0.12s;" onpointerdown="this.style.background='#4b5563'" onpointerup="this.style.background='#374151'" onpointerleave="this.style.background='#374151'">猬囷笍 涓嬭浇</button>
    <button onclick="mobBatchDelete()" style="display:flex;align-items:center;gap:4px;border:none;background:#ef4444;color:#fff;font-size:12px;cursor:pointer;padding:8px 16px;border-radius:8px;transition:background 0.12s;" onpointerdown="this.style.background='#dc2626'" onpointerup="this.style.background='#ef4444'" onpointerleave="this.style.background='#ef4444'">馃棏锔?鍒犻櫎</button>
  </div>
</div>

<!-- 鈺愨晲鈺?鍐呭祵绉诲姩绔?JS 鈺愨晲鈺?-->
<script>
// 鈹€鈹€ Tab 鍒囨崲 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
window.switchMobTab=function(tab){
  document.querySelectorAll('.m-mob-tab').forEach(function(b){
    if(b.getAttribute('data-tab')===tab){
      b.style.background='#3b82f6'; b.style.color='#fff'; b.style.fontWeight='600';
    } else {
      b.style.background='transparent'; b.style.color='#6b7280'; b.style.fontWeight='400';
    }
  });
  document.querySelectorAll('.mob-tab-content').forEach(function(c){ c.style.display='none'; });
  var el=document.getElementById('mob-tab-'+tab);
  if(el) el.style.display='block';
  // 鑱斿姩妗岄潰绔?filter
  var curFilter=document.querySelector('.mob-filter-btn.active');
  var filterType=curFilter?curFilter.getAttribute('data-filter')||'all':'all';
  if(typeof filterMyWorks==='function') filterMyWorks();
};

// 鈹€鈹€ 绫诲瀷杩囨护 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
window.filterMobType=function(type){
  document.querySelectorAll('.mob-filter-btn').forEach(function(b){
    var ft=b.getAttribute('data-filter');
    if(ft===type){
      b.style.borderColor='#3b82f6'; b.style.background='#3b82f6'; b.style.color='#fff';
    } else {
      b.style.borderColor='#333'; b.style.background='transparent'; b.style.color='#9ca3af';
    }
  });
  // 杩囨护褰撳墠Tab鐨勫崱鐗?
  var activeTab=document.querySelector('.m-mob-tab.active')||document.querySelector('.m-mob-tab[style*="background: #3b82f6"]');
  var tabId=activeTab?activeTab.getAttribute('data-tab'):'works';
  document.querySelectorAll('#mob-tab-'+tabId+' .mob-card').forEach(function(card){
    if(type==='all'||card.getAttribute('data-type')===type){
      card.style.display='';
    } else {
      card.style.display='none';
    }
  });
};

// 鈹€鈹€ 棰勮 Bottom Sheet 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
window._mobCurrCard=null;

window.mobGetCurrCard=function(){ return window._mobCurrCard; };

window.mobOpenPreview=function(card){
  window._mobCurrCard=card;
  var name=card.getAttribute('data-name')||'';
  var type=card.getAttribute('data-type')||'image';
  var model=card.getAttribute('data-model')||'';
  var params=card.getAttribute('data-params')||'';
  var prompt=card.getAttribute('data-prompt')||'';
  var source=card.getAttribute('data-source')||'';
  var cost=card.getAttribute('data-cost')||'';
  var taskId=card.getAttribute('data-taskid')||'';
  var created=card.getAttribute('data-created')||'';
  var expires=card.getAttribute('data-expires')||'';
  var category=card.getAttribute('data-category')||'';
  var price=card.getAttribute('data-price')||'';
  var emojiEl=card.querySelector('.mob-card-img .text-4xl');
  if(!emojiEl) emojiEl=card.querySelector('.mob-card-img span:nth-child(3)');
  var emoji=emojiEl?emojiEl.textContent:'馃摝';
  var typeLabels={image:'鍥剧墖搴?,video:'瑙嗛搴?,audio:'闊抽搴?,text:'鏂囨湰搴?};
  var sourceTagMap={image:'澶фā鍨?,video:'澶фā鍨?,audio:'澶фā鍨?,text:'鏂囨湰妯″瀷'};

  // 鍒ゆ柇鏄惁宸插彂甯冿細鏈?data-price 鍗充负宸插彂甯冿紝鍚﹀垯涓鸿崏绋?
  var isPublished=!!card.getAttribute('data-price');
  
  // 宸插彂甯冧骇鍝佹樉绀?浜у搧鍚嶇О/鍒嗙被鏍囩/浣跨敤浠锋牸锛岃崏绋块殣钘?
  ['mob-section-title','mob-section-category','mob-section-price'].forEach(function(id){
    var el=document.getElementById(id);
    if(el) el.style.display=isPublished?'':'none';
  });

  // 浜у搧鍚嶇О
  var titleEl=document.getElementById('mob-info-title');
  if(titleEl) titleEl.textContent=name||'鏈懡鍚?;

  // 鍒嗙被鏍囩
  var catEl=document.getElementById('mob-info-category');
  if(catEl){
    var catColors={
      鍟嗕笟:{bg:'#dbeafe',color:'#1d4ed8',icon:'馃捈'},
      钀ラ攢:{bg:'#fef3c7',color:'#b45309',icon:'馃搳'},
      鑹烘湳:{bg:'#fce7f3',color:'#be185d',icon:'馃帹'},
      鏂囨:{bg:'#fef3c7',color:'#b45309',icon:'鉁嶏笍'},
      瑙嗛:{bg:'#e0e7ff',color:'#4338ca',icon:'馃幀'},
      鍥剧墖:{bg:'#d1fae5',color:'#059669',icon:'馃柤锔?},
      鎽勫奖:{bg:'#e0e7ff',color:'#4338ca',icon:'馃摲'}
    };
    if(category&&catColors[category]){
      var c=catColors[category];
      catEl.innerHTML='<span style="display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:4px;font-size:11px;background:'+c.bg+';color:'+c.color+';">'+c.icon+' '+category+'</span>';
    } else if(category){
      catEl.innerHTML='<span style="display:inline-flex;align-items:center;padding:2px 8px;border-radius:4px;font-size:11px;background:#e5e7eb;color:#6b7280;">'+category+'</span>';
    } else {
      catEl.innerHTML='<span style="display:inline-flex;align-items:center;padding:2px 8px;border-radius:4px;font-size:11px;background:#e5e7eb;color:#6b7280;">鏈垎绫?/span>';
    }
  }

  // 浣跨敤浠锋牸
  var priceEl=document.getElementById('mob-info-price');
  if(priceEl){
    var priceNum=parseFloat(price);
    if(price==='鍏嶈垂'||price==='0'||priceNum===0){
      priceEl.innerHTML='馃啌 鍏嶈垂';
    } else if(priceNum>0){
      priceEl.innerHTML='鈿?<span style="font-family:monospace;">'+priceNum.toFixed(2)+'</span> /娆?;
    } else if(price){
      priceEl.textContent=price;
    } else {
      priceEl.innerHTML='<span style="color:#6b7280;font-size:13px;">鏈畾浠?/span>';
    }
  }

  // 鐐硅禐/璇勮/鑺辫垂
  var likes=card.getAttribute('data-likes')||'0';
  var comments=card.getAttribute('data-comments')||'0';
  var likeCountEl=document.getElementById('mob-like-count');
  var commentCountEl=document.getElementById('mob-comment-count');
  var costDispEl=document.getElementById('mob-info-cost-display');
  if(likeCountEl) likeCountEl.textContent=likes;
  if(commentCountEl) commentCountEl.textContent=comments;
  if(costDispEl) costDispEl.textContent=cost||'0';
  window._mobLiked=false;
  var icon=document.getElementById('mob-like-icon');
  if(icon){icon.setAttribute('fill','none');icon.setAttribute('stroke','#fff');}
  // 浠呭彂甯僒ab鏄剧ず鐐硅禐璇勮鎸夐挳锛堟湁data-likes灞炴€э級
  var hasSocial=card.hasAttribute('data-likes');
  var likeBtn=document.getElementById('mob-like-btn');
  var commentBtn=document.getElementById('mob-comment-btn');
  if(likeBtn) likeBtn.style.display=hasSocial?'flex':'none';
  if(commentBtn) commentBtn.style.display=hasSocial?'flex':'none';

  // 鎻愮ず璇?鈥?鏄剧ず瀹為檯鎻愮ず璇嶏紝瀛樺叆 hidden 鐢ㄤ簬澶嶅埗
  window._mobPromptText=prompt||'';
  var promptEl=document.getElementById('mob-info-prompt');
  if(promptEl) promptEl.textContent=prompt||name||'锛堟棤鎻愮ず璇嶏級';

  // 鏉ユ簮 鈥?钃濊壊鏍囩 + 妯″瀷鍚嶏紙PC绔€昏緫锛歞ata-source-name 鎴?data-name 浣滀负鏉ユ簮鍚嶇О锛?
  var tagEl=document.getElementById('mob-info-source-tag');
  if(tagEl) tagEl.textContent=sourceTagMap[type]||'澶фā鍨?;
  var srcEl=document.getElementById('mob-info-source');
  if(srcEl){
    var srcName=card.getAttribute('data-source-name')||'';
    srcEl.textContent=srcName||model||'鏈寚瀹?;
  }

  // 浣跨敤妯″瀷
  var modelEl=document.getElementById('mob-info-model');
  if(modelEl) modelEl.textContent=model||'鏈寚瀹?;

  // 鍙傛暟閰嶇疆
  var paramEl=document.getElementById('mob-info-params');
  if(paramEl) paramEl.textContent=params||'Auto / 0:16 / 2k / 璐ㄩ噺锛氫腑';

  // 浠诲姟娑堣垂
  var costEl=document.getElementById('mob-info-cost');
  if(costEl) costEl.textContent=cost||'鈿?0.01';

  // TaskId 鈥?瀛樺埌 hidden锛圥C绔敓鎴愰殢鏈篿d锛?
  if(!taskId) taskId='17796745558069535'+Math.floor(Math.random()*90+10);
  window._mobTaskIdText=taskId;
  var tidEl=document.getElementById('mob-info-taskid');
  if(tidEl) tidEl.textContent=taskId;

  // 鍒涘缓鏃堕棿/杩囨湡鏃堕棿锛圥C绔娇鐢ㄥ綋鍓嶆椂闂翠綔涓哄洖閫€锛?
  var now=new Date();
  var fmtShort=function(d){
    return d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate()+' '+d.getHours().toString().padStart(2,'0')+':'+d.getMinutes().toString().padStart(2,'0')+':'+d.getSeconds().toString().padStart(2,'0');
  };
  var createdEl=document.getElementById('mob-info-created');
  if(createdEl) createdEl.textContent=created||fmtShort(now);
  var expiresEl=document.getElementById('mob-info-expires');
  if(expiresEl){
    var exp=expires||new Date(now.getTime()+13*24*60*60*1000);
    expiresEl.textContent=(typeof exp==='string')?exp:fmtShort(exp);
  }

  // 棰勮鍥?
  var media=document.getElementById('mob-preview-media');
  var pe=document.getElementById('mob-preview-emoji');
  if(pe) pe.textContent=emoji;
  if(media){
    if(type==='video') media.style.aspectRatio='16/9';
    else if(type==='audio') media.style.aspectRatio='1/1';
    else media.style.aspectRatio='4/5';
  }

  // 搴曢儴淇℃伅
  var tEl=document.getElementById('mob-preview-type-text');
  if(tEl) tEl.textContent=typeLabels[type]||'鍥剧墖搴?;
  var cntEl=document.getElementById('mob-preview-count');
  if(cntEl) cntEl.textContent='鍏?1 寮?;
  var te=document.getElementById('mob-thumb-emoji');
  if(te) te.textContent=emoji;

  document.getElementById('mob-preview-sheet').style.display='block';
  document.body.style.overflow='hidden';

  window._mobDrawerOpen=false;
  var drawer=document.getElementById('mob-preview-drawer');
  if(drawer) drawer.style.left='-300px';
};

// 澶嶅埗鎻愮ず璇?
