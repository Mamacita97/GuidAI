<!-- 鎵嬫満绔壒閲忔搷浣滄爮 -->
<div id="mob-batch-bar" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:200075;background:#1a1a1a;border-top:1px solid #2a2a2a;padding:10px 16px max(24px,env(safe-area-inset-bottom,24px));align-items:center;justify-content:space-between;transition:transform 0.2s;">
  <button onclick="mobBatchSelectAll()" style="display:flex;align-items:center;gap:6px;border:none;background:transparent;color:#9ca3af;font-size:13px;cursor:pointer;padding:6px 10px;border-radius:8px;transition:background 0.12s;" onpointerdown="this.style.background='rgba(255,255,255,0.06)'" onpointerup="this.style.background='transparent'" onpointerleave="this.style.background='transparent'">
    <span id="mob-batch-check-icon" style="width:18px;height:18px;border-radius:4px;border:2px solid #6b7280;display:flex;align-items:center;justify-content:center;font-size:11px;color:#fff;"></span> 鍏ㄩ€?
  </button>
