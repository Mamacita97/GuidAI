                  <div onclick="selectChatModel('Grok 3','🤖')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer">
                    <div class="flex items-center justify-between"><div class="flex items-center gap-2"><span>🤖</span><span class="text-[11px] font-medium">Grok 3</span></div></div>
                    <div class="text-[9px] text-gray-400 mt-0.5 ml-6 inline-flex items-center gap-0.5"><span class="text-yellow-500 leading-none" aria-hidden="true">⚡</span>5.00 / 1M tokens</div>
                  </div>
                  <div onclick="selectChatModel('Qwen Max','🐎')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer">
                    <div class="flex items-center justify-between"><div class="flex items-center gap-2"><span>🐎</span><span class="text-[11px] font-medium">Qwen Max</span></div></div>
                    <div class="text-[9px] text-gray-400 mt-0.5 ml-6 inline-flex items-center gap-0.5"><span class="text-yellow-500 leading-none" aria-hidden="true">⚡</span>0.50 / 1M tokens</div>
                  </div>
                  <div onclick="selectChatModel('Moonshot V1','🌙')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer">
                    <div class="flex items-center justify-between"><div class="flex items-center gap-2"><span>🌙</span><span class="text-[11px] font-medium">Moonshot V1</span></div></div>
                    <div class="text-[9px] text-gray-400 mt-0.5 ml-6 inline-flex items-center gap-0.5"><span class="text-yellow-500 leading-none" aria-hidden="true">⚡</span>3.00 / 1M tokens</div>
                  </div>
                  <div onclick="selectChatModel('ChatGLM-4','📊')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer">
                    <div class="flex items-center justify-between"><div class="flex items-center gap-2"><span>📊</span><span class="text-[11px] font-medium">ChatGLM-4</span></div></div>
                    <div class="text-[9px] text-gray-400 mt-0.5 ml-6 inline-flex items-center gap-0.5"><span class="text-yellow-500 leading-none" aria-hidden="true">⚡</span>0.50 / 1M tokens</div>
                  </div>
                </div>
              </div>
            </div>

            <!-- 选择角色下拉菜单 -->
            <div class="relative" id="role-dropdown-container">
              <button type="button" onclick="toggleRoleDropdown(event)" class="text-[10px] px-2 py-1 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-500 hover:bg-gray-50 dark:hover:bg-gray-700 transition flex items-center gap-1">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <span id="current-role-text">选择角色</span>
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
              </button>
              <!-- 下拉菜单 -->
              <div id="role-dropdown" class="chat-picker-panel hidden absolute bottom-full left-0 mb-1 w-44 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-lg overflow-hidden z-50">
                <div onclick="openCreateRole()" class="px-3 py-2 text-[11px] text-blue-500 hover:bg-blue-50 dark:hover:bg-blue-900/20 cursor-pointer flex items-center gap-2 border-b border-gray-100 dark:border-gray-700">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  新建角色
                </div>
                <div class="chat-picker-list py-1 max-h-48 overflow-y-auto">
                  <div onclick="selectChatRoleFromDropdown('写作助手','✍️')" class="role-item px-3 py-1.5 text-[11px] hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer flex items-center gap-2">
                    <span>✍️</span><span>写作助手</span>
                  </div>
                  <div onclick="selectChatRoleFromDropdown('文案助手','📝')" class="role-item px-3 py-1.5 text-[11px] hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer flex items-center gap-2">
                    <span>📝</span><span>文案助手</span>
                  </div>
                  <div onclick="selectChatRoleFromDropdown('商业顾问','💼')" class="role-item px-3 py-1.5 text-[11px] hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer flex items-center gap-2">
                    <span>💼</span><span>商业顾问</span>
                  </div>
                  <div onclick="selectChatRoleFromDropdown('数据顾问','📊')" class="role-item px-3 py-1.5 text-[11px] hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer flex items-center gap-2">
                    <span>📊</span><span>数据顾问</span>
                  </div>
                  <div onclick="selectChatRoleFromDropdown('代码助手','💻')" class="role-item px-3 py-1.5 text-[11px] hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer flex items-center gap-2">
                    <span>💻</span><span>代码助手</span>
                  </div>
                  <div onclick="selectChatRoleFromDropdown('翻译官','🌐')" class="role-item px-3 py-1.5 text-[11px] hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer flex items-center gap-2">
                    <span>🌐</span><span>翻译官</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- 多模型协作按钮 -->
            <button id="collab-toggle-btn" onclick="toggleCollabMode(this)" class="text-[10px] px-2 py-1 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition flex items-center gap-1.5">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
              <span>多模型协作</span>
            </button>
            <!-- 退出协作按钮 -->
            <button id="exit-collab-btn" onclick="exitCollabMode()" class="hidden text-[10px] px-1.5 py-1 rounded-lg border border-red-200 dark:border-red-700 text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition flex items-center justify-center" title="退出协作模式">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>

            <button onclick="toggleDeepThink(this)" class="text-[10px] px-2 py-1 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-500 hover:bg-gray-50 dark:hover:bg-gray-700 transition flex items-center gap-1 deepthink-btn">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 1 1 7.072 0l-.548.547A3.374 3.374 0 0 0 14 18.469V19a2 2 0 1 1-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
              深度思考
            </button>
            <button onclick="toggleSearch(this)" class="text-[10px] px-2 py-1 rounded-lg border border-blue-300 dark:border-blue-600 bg-blue-50 dark:bg-blue-900/30 text-blue-600 hover:bg-blue-100 dark:hover:bg-blue-900/50 transition flex items-center gap-1 search-btn active">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              联网搜索
            </button>
            <!-- 预设模板下拉框 -->
            <select id="preset-template-select" class="text-[10px] border border-gray-200 dark:border-gray-600 rounded-lg px-2 py-1 bg-white dark:bg-gray-800 text-gray-500 outline-none cursor-pointer" onchange="applyPresetTemplate(this.value)">
              <option value="">📋 预设模板</option>
              <option value="writing">✍️ 爆款写作模板</option>
              <option value="social">📱 社媒文案模板</option>
              <option value="business">💼 商业分析模板</option>
              <option value="data">📊 数据洞察模板</option>
              <option value="code">💻 代码审查模板</option>
              <option value="translate">🌐 翻译润色模板</option>
            </select>
            <span id="chat-gen-cost" class="text-[11px] font-medium px-2 py-1 bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-lg border border-blue-100 dark:border-blue-800 shrink-0 whitespace-nowrap inline-flex items-center gap-0.5">💰 预估: <span class="text-yellow-500 leading-none" aria-hidden="true">⚡</span>0.0022-0.0065/次</span>
          </div>
          </div>
          <button type="button" class="send-btn chat-send-btn hidden md:flex w-7 h-7 rounded-full bg-blue-500 hover:bg-blue-600 text-white items-center justify-center transition shrink-0" title="发送">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>
          </button>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

    <section id="page-image" class="page-section relative">
  <!-- 全屏画框 -->
  <div id="image-canvas-area" class="bg-gradient-to-br from-gray-100 to-gray-200 dark:from-gray-800 dark:to-gray-700 flex items-start justify-center overflow-auto">
    <!-- 生成结果容器（存放所有生成结果卡片 + 内嵌生成进度） -->
    <div id="image-results-container" class="image-results--empty flex flex-col items-center w-full max-w-5xl mx-auto px-4 pt-4 gap-6 pb-4">
      <div id="image-hot-apps-mount" class="w-full max-w-3xl"></div>
      <div id="image-empty-state" class="w-full text-center text-gray-400 dark:text-gray-500 text-xs py-2">
        <div class="text-2xl mb-1">🖼️</div>
        <div>描述你想要的画面，或上传参考图开始创作</div>
      </div>
      <!-- 结果卡片动态追加到这里 -->
      <!-- 生成中状态（内嵌在结果流，非居中弹窗） -->
      <div id="image-generating-state" class="hidden w-full bg-white/80 dark:bg-gray-800/80 backdrop-blur rounded-2xl shadow-lg p-4 scroll-mt-4">
        <div class="flex items-center gap-2 mb-3 text-[11px] text-amber-600 dark:text-amber-400 font-medium">
          <span class="inline-block w-2 h-2 rounded-full bg-amber-500 animate-pulse"></span>
          <span>生成中</span>
        </div>
        <div class="w-full flex flex-wrap items-center gap-x-3 gap-y-1 mb-3 text-[11px] text-gray-600 dark:text-gray-400">
          <span id="gen-model" class="shrink-0">Auto</span>
          <span class="text-gray-300 dark:text-gray-600">|</span>
          <span id="gen-ratio" class="shrink-0">16:9</span>
          <span class="text-gray-300 dark:text-gray-600">|</span>
          <span id="gen-quality" class="shrink-0">2k</span>
        </div>
        <p id="gen-prompt" class="result-prompt-text text-gray-700 dark:text-gray-300 mb-3 text-[12px] w-full"><span class="result-prompt-body">图1的衣服换成白色，图2的衣服换成黑色</span><span class="result-prompt-toggle-hint hidden"></span></p>
        <div id="gen-ref-thumbs" class="flex items-center gap-2 flex-wrap mb-4"></div>
        <div class="rounded-xl border border-dashed border-gray-200 dark:border-gray-600 bg-gray-50/80 dark:bg-gray-900/40 p-6">
          <div class="w-full flex items-center gap-3">
            <div class="flex-1 h-2 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
              <div id="gen-progress-bar" class="h-full bg-gradient-to-r from-green-500 to-teal-500 rounded-full transition-all duration-300" style="width: 0%"></div>
            </div>
            <span id="gen-status-text" class="text-[12px] text-gray-500 dark:text-gray-400 whitespace-nowrap tabular-nums">0%</span>
          </div>
          <div class="text-[12px] text-gray-500 dark:text-gray-400 mt-2">
            <span id="gen-status-detail">正在准备任务...</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ 参考图区域（默认隐藏，上传后显示） ═══ -->
  <div id="ref-image-section" class="hidden shrink-0">
    <div class="flex items-center gap-2 mb-3"><div class="h-px flex-1 bg-gray-400/30"></div><span class="text-[11px] font-semibold text-gray-300 shrink-0">参考图区域</span><div class="h-px flex-1 bg-gray-400/30"></div></div>
    <div class="flex items-center gap-2 overflow-x-auto pb-1" id="ref-image-area">
      <div class="w-14 h-14 rounded-xl border-2 border-dashed border-gray-400/50 flex items-center justify-center text-gray-300 text-lg cursor-pointer hover:border-blue-400 shrink-0" data-open-asset-modal onclick="openImageAssetModal()">+</div>
      <div class="text-[9px] text-gray-300 shrink-0">最多14张</div>
    </div>
  </div>

  <!-- 浮动输入框 -->
  <div id="image-input-area" class="pointer-events-auto">
    <div class="bg-white/95 dark:bg-gray-800/95 backdrop-blur border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg">
      <!-- 输入区 -->
      <div class="relative px-4 pt-3 pb-2">
        <!-- 参考图预览区域 -->
        <div id="image-ref-preview-area" class="flex items-center gap-2 mb-3 pb-3 border-b border-gray-100 dark:border-gray-700">
          <div class="flex items-center gap-2 overflow-x-auto pb-1" id="image-ref-thumbnails">
            <!-- 缩略图将动态插入到这里 -->
          </div>
        </div>
        <textarea placeholder="描述你想要生成的图片内容，支持上传参考图片进行图生图，最多14张" class="w-full text-xs border-0 bg-transparent outline-none resize-none leading-relaxed" rows="6" id="image-prompt-input"></textarea>
      </div>
      <!-- 工具栏 -->
      <div class="media-toolbar-row flex flex-wrap items-center gap-2 px-3 py-2 border-t border-gray-100 dark:border-gray-700">
        <!-- 手机端：图标工具栏 -->
        <div class="media-toolbar-mobile hidden">
          <div class="media-tool-icons">
            <button type="button" id="img-m-icon-model" class="media-tool-icon" title="图片模型" onclick="openImageMobileSheet('model',event)">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
            </button>
            <button type="button" id="img-m-icon-role" class="media-tool-icon" title="提示词优化" onclick="openImagePromptOptimizeModal(event)">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l2.4 7.2H22l-6 4.6 2.3 7.2L12 16.4 5.7 21l2.3-7.2-6-4.6h7.6z"/></svg>
            </button>
            <button type="button" id="img-m-icon-params" class="media-tool-icon" title="输出参数" onclick="openImageMobileSheet('params',event)">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 12h8M12 8v8"/></svg>
            </button>
            <button type="button" id="img-m-icon-preset" class="media-tool-icon" title="风格预设" onclick="openImageMobileSheet('preset',event)">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </button>
            <button type="button" id="img-m-icon-voice" class="media-tool-icon mobile-voice-btn" title="语音输入（再次点击结束）" data-voice-input="image-prompt-input" onclick="toggleMobileVoiceInput(event)">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
            </button>
          </div>
          <button type="button" id="image-gen-btn-mobile" onclick="startImageGeneration()" class="media-gen-btn gen-btn px-3 py-1.5 bg-gradient-to-r from-blue-500 to-purple-600 text-white text-xs font-semibold rounded-xl hover:from-blue-600 hover:to-purple-700 transition">✨ 生成</button>
        </div>
        <!-- 桌面端：完整工具栏 -->
        <div class="media-toolbar-desktop flex flex-wrap items-center gap-2 w-full">
        <!-- 模型选择 -->
        <div class="relative" id="image-model-dropdown-container">
          <button type="button" onclick="toggleImageModelDropdown(event)" class="text-[10px] px-2 py-1 rounded-lg border border-gray-200 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 transition flex items-center gap-1.5 bg-gradient-to-r from-blue-50 to-purple-50 dark:from-blue-900/20 dark:to-purple-900/20">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
            <span id="current-image-model-text" class="text-gray-600 dark:text-gray-400 font-medium">Auto</span>
            <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <!-- 模型下拉菜单 -->
          <div id="image-model-dropdown" class="hidden absolute bottom-full left-0 mb-1 w-72 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-lg overflow-hidden z-50">
            <div class="px-3 py-2 text-[10px] text-gray-400 border-b border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">🔥 热门图片模型</div>
            <div class="py-1 max-h-60 overflow-y-auto">
              <div onclick="selectImageModel('Auto','✨')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer border-b border-gray-100 dark:border-gray-700/80">
                <div class="flex items-center justify-between"><div class="flex items-center gap-2"><span>✨</span><span class="text-[11px] font-medium">Auto</span></div><span class="text-[9px] px-1.5 py-0.5 bg-green-100 dark:bg-green-900/30 text-green-600 rounded">推荐</span></div>
                <div class="text-[9px] text-gray-400 mt-0.5 ml-6">自动选择最优模型</div>
              </div>
              <div onclick="selectImageModel('Nano Banana Pro','🍌')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer">
                <div class="flex items-center justify-between"><div class="flex items-center gap-2"><span>🍌</span><span class="text-[11px] font-medium">Nano Banana Pro</span></div><span class="text-[9px] px-1.5 py-0.5 bg-blue-100 dark:bg-blue-900/30 text-blue-600 rounded">热门</span></div>
                <div class="text-[9px] text-gray-400 mt-0.5 ml-6 inline-flex items-center gap-0.5"><span class="text-yellow-500 leading-none" aria-hidden="true">⚡</span>0.002 / 张</div>
              </div>
              <div onclick="selectImageModel('Midjourney 7','🎨')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer">
                <div class="flex items-center justify-between"><div class="flex items-center gap-2"><span>🎨</span><span class="text-[11px] font-medium">Midjourney 7</span></div><span class="text-[9px] px-1.5 py-0.5 bg-orange-100 dark:bg-orange-900/30 text-orange-600 rounded">热门</span></div>
                <div class="text-[9px] text-gray-400 mt-0.5 ml-6 inline-flex items-center gap-0.5"><span class="text-yellow-500 leading-none" aria-hidden="true">⚡</span>0.01 / 张</div>
              </div>
              <div onclick="selectImageModel('DALL·E 5','🖌️')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer">
                <div class="flex items-center justify-between"><div class="flex items-center gap-2"><span>🖌️</span><span class="text-[11px] font-medium">DALL·E 5</span></div></div>
                <div class="text-[9px] text-gray-400 mt-0.5 ml-6 inline-flex items-center gap-0.5"><span class="text-yellow-500 leading-none" aria-hidden="true">⚡</span>0.005 / 张</div>
              </div>
              <div onclick="selectImageModel('Stable Diffusion 5','🧪')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer">
                <div class="flex items-center justify-between"><div class="flex items-center gap-2"><span>🧪</span><span class="text-[11px] font-medium">Stable Diffusion 5</span></div><span class="text-[9px] px-1.5 py-0.5 bg-blue-100 dark:bg-blue-900/30 text-blue-600 rounded">性价比</span></div>
                <div class="text-[9px] text-gray-400 mt-0.5 ml-6 inline-flex items-center gap-0.5"><span class="text-yellow-500 leading-none" aria-hidden="true">⚡</span>0.001 / 张</div>
              </div>
              <div onclick="selectImageModel('Flux.1 Pro','⚡')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer">
                <div class="flex items-center justify-between"><div class="flex items-center gap-2"><span>⚡</span><span class="text-[11px] font-medium">Flux.1 Pro</span></div></div>
                <div class="text-[9px] text-gray-400 mt-0.5 ml-6 inline-flex items-center gap-0.5"><span class="text-yellow-500 leading-none" aria-hidden="true">⚡</span>0.02 / 张</div>
              </div>
            </div>
          </div>
        </div>
        <!-- 提示词优化 -->
        <div class="relative" id="image-role-dropdown-container">
          <button type="button" onclick="openImagePromptOptimizeModal(event)" class="text-[10px] px-2 py-1 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-500 hover:bg-gray-50 dark:hover:bg-gray-700 transition flex items-center gap-1">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l2.4 7.2H22l-6 4.6 2.3 7.2L12 16.4 5.7 21l2.3-7.2-6-4.6h7.6z"/></svg>
            <span id="current-image-role-text">提示词优化</span>
            <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <!-- 提示词优化下拉菜单 -->
          <div id="image-role-dropdown" class="hidden absolute bottom-full left-0 mb-1 w-48 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-lg overflow-hidden z-50">
            <div class="px-3 py-2 text-[10px] text-gray-400 border-b border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">✨ 提示词优化</div>
            <div class="py-1 max-h-60 overflow-y-auto">
              <div onclick="openImagePromptOptimizeModal(event,'电商海报')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer">
                <div class="flex items-center gap-2"><span>🛍️</span><span class="text-[11px]">电商海报</span></div>
              </div>
              <div onclick="openImagePromptOptimizeModal(event,'人像写真')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer">
                <div class="flex items-center gap-2"><span>👤</span><span class="text-[11px]">人像写真</span></div>
              </div>
              <div onclick="openImagePromptOptimizeModal(event,'概念插画')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer">
                <div class="flex items-center gap-2"><span>🎨</span><span class="text-[11px]">概念插画</span></div>
              </div>
              <div onclick="openImagePromptOptimizeModal(event,'自然风光')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer">
                <div class="flex items-center gap-2"><span>🏔️</span><span class="text-[11px]">自然风光</span></div>
              </div>
              <div onclick="openImagePromptOptimizeModal(event,'美食摄影')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer">
                <div class="flex items-center gap-2"><span>🍜</span><span class="text-[11px]">美食摄影</span></div>
              </div>
            </div>
          </div>
        </div>
        <!-- 输出参数（条数 / 比例 / 分辨率 / 质量） -->
        <div class="relative shrink-0" id="image-output-params-wrap">
          <button type="button" onclick="toggleImageOutputParamsDropdown(event)" class="text-[10px] px-2.5 py-1 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700/50 hover:bg-gray-100 dark:hover:bg-gray-600 transition flex items-center gap-1.5 text-gray-700 dark:text-gray-200">
            <svg class="shrink-0 text-gray-500 dark:text-gray-400" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
            <span id="image-output-params-label" class="whitespace-nowrap">1条 / 0:16 / 2k / 中</span>
            <svg class="shrink-0 text-gray-400" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div id="image-output-params-dropdown" class="hidden absolute bottom-full left-0 mb-1 w-[300px] output-params-panel shadow-2xl overflow-hidden z-50 max-h-[70vh] overflow-y-auto">
            <div class="px-3 pt-3 pb-2 border-b border-gray-700/80">
              <div class="vop-section-title">生成条数</div>
              <div class="grid grid-cols-4 gap-1">
                <button type="button" onclick="setImageOutputParam('count','1条')" data-iparam="count" data-ivalue="1条" class="param-count-opt text-[10px] py-1.5">1条</button>
                <button type="button" onclick="setImageOutputParam('count','2条')" data-iparam="count" data-ivalue="2条" class="param-count-opt text-[10px] py-1.5">2条</button>
                <button type="button" onclick="setImageOutputParam('count','4条')" data-iparam="count" data-ivalue="4条" class="param-count-opt text-[10px] py-1.5">4条</button>
                <button type="button" onclick="setImageOutputParam('count','6条')" data-iparam="count" data-ivalue="6条" class="param-count-opt text-[10px] py-1.5">6条</button>
              </div>
            </div>
            <div class="px-3 py-2 border-b border-gray-700/80">
              <div class="vop-section-title">图片比例</div>
              <div class="grid grid-cols-6 gap-1">
                <button type="button" onclick="setImageOutputParam('ratio','Auto')" data-iparam="ratio" data-ivalue="Auto" class="param-ratio-opt flex flex-col items-center gap-0.5 py-1 text-[8px]"><span class="w-3.5 h-3.5 border border-dashed border-current rounded-[2px] opacity-70"></span>Auto</button>
                <button type="button" onclick="setImageOutputParam('ratio','1:1')" data-iparam="ratio" data-ivalue="1:1" class="param-ratio-opt flex flex-col items-center gap-0.5 py-1 text-[8px]"><span class="w-3.5 h-3.5 border border-current rounded-[2px]"></span>1:1</button>
                <button type="button" onclick="setImageOutputParam('ratio','2:3')" data-iparam="ratio" data-ivalue="2:3" class="param-ratio-opt flex flex-col items-center gap-0.5 py-1 text-[8px]"><span class="w-2.5 h-4 border border-current rounded-[2px]"></span>2:3</button>
                <button type="button" onclick="setImageOutputParam('ratio','3:2')" data-iparam="ratio" data-ivalue="3:2" class="param-ratio-opt flex flex-col items-center gap-0.5 py-1 text-[8px]"><span class="w-4 h-2.5 border border-current rounded-[2px]"></span>3:2</button>
                <button type="button" onclick="setImageOutputParam('ratio','3:4')" data-iparam="ratio" data-ivalue="3:4" class="param-ratio-opt flex flex-col items-center gap-0.5 py-1 text-[8px]"><span class="w-3 h-4 border border-current rounded-[2px]"></span>3:4</button>
                <button type="button" onclick="setImageOutputParam('ratio','4:3')" data-iparam="ratio" data-ivalue="4:3" class="param-ratio-opt flex flex-col items-center gap-0.5 py-1 text-[8px]"><span class="w-4 h-3 border border-current rounded-[2px]"></span>4:3</button>
                <button type="button" onclick="setImageOutputParam('ratio','4:5')" data-iparam="ratio" data-ivalue="4:5" class="param-ratio-opt flex flex-col items-center gap-0.5 py-1 text-[8px]"><span class="w-2.5 h-3.5 border border-current rounded-[2px]"></span>4:5</button>
                <button type="button" onclick="setImageOutputParam('ratio','5:4')" data-iparam="ratio" data-ivalue="5:4" class="param-ratio-opt flex flex-col items-center gap-0.5 py-1 text-[8px]"><span class="w-3.5 h-2.5 border border-current rounded-[2px]"></span>5:4</button>
                <button type="button" onclick="setImageOutputParam('ratio','9:16')" data-iparam="ratio" data-ivalue="9:16" class="param-ratio-opt flex flex-col items-center gap-0.5 py-1 text-[8px]"><span class="w-2.5 h-5 border border-current rounded-[2px]"></span>9:16</button>
                <button type="button" onclick="setImageOutputParam('ratio','16:9')" data-iparam="ratio" data-ivalue="16:9" class="param-ratio-opt flex flex-col items-center gap-0.5 py-1 text-[8px]"><span class="w-5 h-2.5 border border-current rounded-[2px]"></span>16:9</button>
                <button type="button" onclick="setImageOutputParam('ratio','21:9')" data-iparam="ratio" data-ivalue="21:9" class="param-ratio-opt flex flex-col items-center gap-0.5 py-1 text-[8px] col-span-2"><span class="w-6 h-2 border border-current rounded-[2px]"></span>21:9</button>
              </div>
            </div>
            <div class="px-3 py-2 border-b border-gray-700/80">
              <div class="vop-section-title">分辨率</div>
              <div class="flex">
                <button type="button" onclick="setImageOutputParam('quality','1k')" data-iparam="quality" data-ivalue="1k" class="param-seg-opt">1k</button>
                <button type="button" onclick="setImageOutputParam('quality','2k')" data-iparam="quality" data-ivalue="2k" class="param-seg-opt">2k</button>
                <button type="button" onclick="setImageOutputParam('quality','4k')" data-iparam="quality" data-ivalue="4k" class="param-seg-opt">4k</button>
                <button type="button" onclick="setImageOutputParam('quality','8k')" data-iparam="quality" data-ivalue="8k" class="param-seg-opt">8k</button>
              </div>
            </div>
            <div class="px-3 py-2 pb-3">
              <div class="vop-section-title">质量</div>
              <div class="flex">
                <button type="button" onclick="setImageOutputParam('tier','低')" data-iparam="tier" data-ivalue="低" class="param-seg-opt">低</button>
                <button type="button" onclick="setImageOutputParam('tier','中')" data-iparam="tier" data-ivalue="中" class="param-seg-opt">中</button>
                <button type="button" onclick="setImageOutputParam('tier','高')" data-iparam="tier" data-ivalue="高" class="param-seg-opt">高</button>
              </div>
            </div>
          </div>
          <select id="image-param-count" class="hidden" aria-hidden="true"><option selected>1条</option><option>2条</option><option>4条</option><option>6条</option></select>
          <select id="image-param-ratio" class="hidden" aria-hidden="true">
            <option value="0:16" selected>0:16</option><option value="16:9">16:9</option><option value="1:1">1:1</option><option value="3:4">3:4</option>
            <option value="Auto">Auto</option><option value="2:3">2:3</option><option value="3:2">3:2</option><option value="4:3">4:3</option><option value="4:5">4:5</option><option value="5:4">5:4</option><option value="9:16">9:16</option><option value="21:9">21:9</option>
          </select>
          <select id="image-param-quality" class="hidden" aria-hidden="true"><option value="1k">1k</option><option value="2k" selected>2k</option><option value="4k">4k</option><option value="8k">8k</option></select>
          <input type="hidden" id="image-param-tier" value="中">
        </div>
        <select id="image-preset-select" onchange="applyImagePreset(this.value)" class="text-[10px] border border-gray-200 dark:border-gray-600 rounded-lg px-2 py-1 bg-white dark:bg-gray-800 outline-none">
          <option value="">无预设</option>
          <option value="赛博朋克">赛博朋克</option>
          <option value="国风水墨">国风水墨</option>
          <option value="胶片质感">胶片质感</option>
          <option value="莫兰迪色">莫兰迪色</option>
          <option value="复古胶片">复古胶片</option>
        </select>
        <span id="image-gen-cost" class="text-[11px] font-medium px-2 py-1 bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-lg border border-blue-100 dark:border-blue-800 inline-flex items-center gap-0.5">💰 预估: <span class="text-yellow-500 leading-none" aria-hidden="true">⚡</span>0.002/张</span>
        <button type="button" id="image-gen-btn-desktop" onclick="startImageGeneration()" class="gen-btn ml-auto px-4 py-1 bg-gradient-to-r from-blue-500 to-purple-600 text-white text-xs font-semibold rounded-lg hover:from-blue-600 hover:to-purple-700 transition">✨ 生成</button>
        </div>
      </div>
    </div>
  </div>
</section>

    <section id="page-video" class="page-section relative">
  <!-- 视频结果展示区 -->
  <div id="video-canvas-area" class="relative z-0 bg-gradient-to-br from-gray-100 to-gray-200 dark:from-gray-800 dark:to-gray-700 flex items-start justify-center overflow-auto">
    <!-- 空状态（有结果时隐藏，由下方 slot 展示引导 + 热门 Apps） -->
    <div id="video-empty-state" class="hidden absolute inset-0 flex items-center justify-center pointer-events-none z-0">
      <div class="text-center text-gray-400 text-sm">
        <div class="text-4xl mb-2">🎬</div>
        <div>生成的视频将显示在这里</div>
      </div>
    </div>
    <!-- 空窗：中上部热门 Apps -->
    <div id="video-hot-apps-slot" class="video-hot-apps-slot">
      <div id="video-hot-apps-mount" class="w-full max-w-3xl"></div>
      <div id="video-empty-inline" class="w-full max-w-3xl text-center text-gray-400 dark:text-gray-500 text-xs py-2 mb-1">
        <div class="text-2xl mb-1">🎬</div>
        <div>描述你想要的视频，或上传参考素材开始创作</div>
      </div>
    </div>
    <!-- 生成结果容器（含内嵌生成进度） -->
    <div id="video-results-container" class="hidden flex flex-col items-center w-full max-w-5xl mx-auto px-4 pt-4 gap-6 pb-4">
      <!-- 生成中状态（内嵌在结果流，非居中弹窗） -->
      <div id="video-generating-state" class="hidden w-full bg-white/80 dark:bg-gray-800/80 backdrop-blur rounded-2xl shadow-lg p-4 scroll-mt-4">
        <div class="flex items-center gap-2 mb-3 text-[11px] text-amber-600 dark:text-amber-400 font-medium">
          <span class="inline-block w-2 h-2 rounded-full bg-amber-500 animate-pulse"></span>
          <span>生成中</span>
        </div>
        <div class="w-full flex flex-wrap items-center gap-x-3 gap-y-1 mb-3 text-[11px] text-gray-600 dark:text-gray-400">
          <span id="video-gen-model" class="shrink-0">Auto-多模式参考</span>
          <span class="text-gray-300 dark:text-gray-600">|</span>
          <span id="video-gen-ratio" class="shrink-0">16:9</span>
          <span class="text-gray-300 dark:text-gray-600">|</span>
          <span id="video-gen-duration" class="shrink-0">4s</span>
          <span class="text-gray-300 dark:text-gray-600">|</span>
          <span id="video-gen-quality" class="shrink-0">480p</span>
        </div>
        <p id="video-gen-prompt" class="result-prompt-text text-gray-700 dark:text-gray-300 mb-3 text-[12px] w-full"><span class="result-prompt-body">女孩转身</span><span class="result-prompt-toggle-hint hidden"></span></p>
        <div id="video-gen-ref-thumbs" class="flex items-center gap-2 flex-wrap mb-4"></div>
        <div class="rounded-xl border border-dashed border-gray-200 dark:border-gray-600 bg-gray-50/80 dark:bg-gray-900/40 p-6">
          <div class="w-full flex items-center gap-3">
            <div class="flex-1 h-2 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
              <div id="video-gen-progress-bar" class="h-full bg-gradient-to-r from-green-500 to-teal-500 rounded-full transition-all duration-300" style="width:0%"></div>
            </div>
            <span id="video-gen-status-text" class="text-[12px] text-gray-500 dark:text-gray-400 whitespace-nowrap tabular-nums">0%</span>
          </div>
          <div class="text-[12px] text-gray-500 dark:text-gray-400 mt-2">
            <span id="video-gen-status-detail">正在准备任务...</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ 浮动输入框 ═══ -->
  <div id="video-input-area" class="pointer-events-auto">
    <div class="bg-white/95 dark:bg-gray-800/95 backdrop-blur border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg">
    <!-- 参考素材区（按类型分组：按钮 + 缩尾图） -->
    <div class="px-4 pt-3 pb-3 flex items-center gap-2.5 overflow-x-auto" id="video-ref-area">
      <!-- 图片缩略图 + 图片上传 -->
      <div class="flex items-center gap-2 shrink-0">
        <div class="flex items-center gap-2" id="video-ref-thumbnails-image"></div>
        <div onclick="openVideoAssetModal('image')" class="w-[72px] shrink-0 border border-gray-300 dark:border-gray-600 rounded-xl cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-700 transition-all duration-200 flex flex-col items-center justify-center py-2.5 group" title="从我的资产选择图片">
          <span class="text-gray-500 group-hover:text-gray-800 dark:text-gray-400 dark:group-hover:text-gray-200 text-lg leading-none mb-0.5 transition-colors">+</span>
          <span class="text-gray-500 group-hover:text-gray-800 dark:text-gray-400 dark:group-hover:text-gray-200 text-[11px] transition-colors">图片</span>
        </div>
      </div>
      <!-- 视频缩略图 + 视频上传 -->
      <div class="flex items-center gap-2 shrink-0">
        <div class="flex items-center gap-2" id="video-ref-thumbnails-video"></div>
        <div onclick="openVideoAssetModal('video')" class="w-[72px] shrink-0 border border-gray-300 dark:border-gray-600 rounded-xl cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-700 transition-all duration-200 flex flex-col items-center justify-center py-2.5 group" title="从我的资产选择视频">
          <span class="text-gray-500 group-hover:text-gray-800 dark:text-gray-400 dark:group-hover:text-gray-200 text-lg leading-none mb-0.5 transition-colors">+</span>
          <span class="text-gray-500 group-hover:text-gray-800 dark:text-gray-400 dark:group-hover:text-gray-200 text-[11px] transition-colors">视频</span>
        </div>
      </div>
      <!-- 音频缩略图 + 音频上传 -->
      <div class="flex items-center gap-2 shrink-0">
        <div class="flex items-center gap-2" id="video-ref-thumbnails-audio"></div>
        <div onclick="openVideoAssetModal('audio')" class="w-[72px] shrink-0 border border-gray-300 dark:border-gray-600 rounded-xl cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-700 transition-all duration-200 flex flex-col items-center justify-center py-2.5 group" title="从我的资产选择音频">
          <span class="text-gray-500 group-hover:text-gray-800 dark:text-gray-400 dark:group-hover:text-gray-200 text-lg leading-none mb-0.5 transition-colors">+</span>
          <span class="text-gray-500 group-hover:text-gray-800 dark:text-gray-400 dark:group-hover:text-gray-200 text-[11px] transition-colors">音频</span>
        </div>
      </div>
    </div>
    <!-- 输入区 -->
    <div id="video-prompt-wrap" class="relative px-4 pt-3 pb-2">
      <textarea id="video-prompt-textarea" placeholder="描述视频内容、动作和场景..." class="w-full text-xs border-0 bg-transparent outline-none resize-none leading-relaxed" rows="4"></textarea>
    </div>
    <!-- 工具栏 -->
    <div class="media-toolbar-row flex flex-wrap items-center gap-2 px-3 py-2 border-t border-gray-100 dark:border-gray-700">
      <!-- 手机端：图标工具栏 -->
      <div class="media-toolbar-mobile hidden">
        <div class="media-tool-icons">
          <button type="button" id="vid-m-icon-model" class="media-tool-icon" title="视频模型" onclick="openVideoMobileSheet('model',event)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          </button>
          <button type="button" id="vid-m-icon-role" class="media-tool-icon" title="提示词优化" onclick="openVideoPromptOptimizeModal(event)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l2.4 7.2H22l-6 4.6 2.3 7.2L12 16.4 5.7 21l2.3-7.2-6-4.6h7.6z"/></svg>
          </button>
          <button type="button" id="vid-m-icon-params" class="media-tool-icon" title="输出参数" onclick="openVideoMobileSheet('params',event)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 12h8M12 8v8"/></svg>
          </button>
          <button type="button" id="vid-m-icon-mode" class="media-tool-icon" title="生成模式" onclick="openVideoMobileSheet('mode',event)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
          </button>
          <button type="button" id="vid-m-icon-voice" class="media-tool-icon mobile-voice-btn" title="语音输入（再次点击结束）" data-voice-input="video-prompt-textarea" onclick="toggleMobileVoiceInput(event)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
          </button>
        </div>
        <button type="button" id="video-gen-btn-mobile" onclick="startVideoGeneration()" class="media-gen-btn gen-btn px-3 py-1.5 bg-gradient-to-r from-blue-500 to-purple-600 text-white text-xs font-semibold rounded-xl hover:from-blue-600 hover:to-purple-700 transition">✨ 生成</button>
      </div>
      <!-- 桌面端：完整工具栏 -->
      <div class="media-toolbar-desktop flex flex-wrap items-center gap-2 w-full">
      <!-- 模型选择 -->
      <div class="relative" id="video-model-dropdown-container">
        <button type="button" onclick="toggleVideoModelDropdown(event)" class="text-[10px] px-2 py-1 rounded-lg border border-gray-200 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 transition flex items-center gap-1.5 bg-gradient-to-r from-blue-50 to-purple-50 dark:from-blue-900/20 dark:to-purple-900/20">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <span id="current-video-model-text" class="text-gray-600 dark:text-gray-400">Auto</span>
          <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div id="video-model-dropdown" class="hidden absolute bottom-full left-0 mb-1 w-56 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-lg overflow-hidden z-50">
          <div class="px-3 py-2 text-[10px] text-gray-400 border-b border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">🎬 视频模型</div>
          <div class="py-1 max-h-48 overflow-y-auto">
            <div onclick="selectVideoModel('Auto','✨')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer border-b border-gray-100 dark:border-gray-700/80"><div class="flex items-center gap-2"><span>✨</span><span class="text-[11px] font-medium">Auto</span><span class="text-[9px] text-blue-500 ml-auto">推荐</span></div></div>
            <div onclick="selectVideoModel('Sora2','🎬')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer"><div class="flex items-center gap-2"><span>🎬</span><span class="text-[11px]">Sora2</span></div></div>
            <div onclick="selectVideoModel('Kling 2.0','⚡')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer"><div class="flex items-center gap-2"><span>⚡</span><span class="text-[11px]">Kling 2.0</span></div></div>
            <div onclick="selectVideoModel('Runway Gen-4','🚀')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer"><div class="flex items-center gap-2"><span>🚀</span><span class="text-[11px]">Runway Gen-4</span></div></div>
            <div onclick="selectVideoModel('Pika 3.0','🎨')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer"><div class="flex items-center gap-2"><span>🎨</span><span class="text-[11px]">Pika 3.0</span></div></div>
            <div onclick="selectVideoModel('VIDU-音乐MV','🎵')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer"><div class="flex items-center gap-2"><span>🎵</span><span class="text-[11px]">VIDU-音乐MV</span></div></div>
          </div>
        </div>
      </div>
      <!-- 提示词优化 -->
      <div class="relative" id="video-role-dropdown-container">
        <button type="button" onclick="openVideoPromptOptimizeModal(event)" class="text-[10px] px-2 py-1 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-500 hover:bg-gray-50 dark:hover:bg-gray-700 transition flex items-center gap-1">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l2.4 7.2H22l-6 4.6 2.3 7.2L12 16.4 5.7 21l2.3-7.2-6-4.6h7.6z"/></svg>
          <span id="current-video-role-text">提示词优化</span>
          <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div id="video-role-dropdown" class="hidden absolute bottom-full left-0 mb-1 w-48 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-lg overflow-hidden z-50">
          <div class="px-3 py-2 text-[10px] text-gray-400 border-b border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">✨ 提示词优化</div>
          <div class="py-1 max-h-48 overflow-y-auto">
            <div onclick="openVideoPromptOptimizeModal(event,'短视频编导')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer"><div class="flex items-center gap-2"><span>📱</span><span class="text-[11px]">短视频编导</span></div></div>
            <div onclick="openVideoPromptOptimizeModal(event,'广告导演')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer"><div class="flex items-center gap-2"><span>📺</span><span class="text-[11px]">广告导演</span></div></div>
            <div onclick="openVideoPromptOptimizeModal(event,'微电影导演')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer"><div class="flex items-center gap-2"><span>🎥</span><span class="text-[11px]">微电影导演</span></div></div>
            <div onclick="openVideoPromptOptimizeModal(event,'MV导演')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer"><div class="flex items-center gap-2"><span>🎤</span><span class="text-[11px]">MV导演</span></div></div>
            <div onclick="openVideoPromptOptimizeModal(event,'纪录片编导')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer"><div class="flex items-center gap-2"><span>📽️</span><span class="text-[11px]">纪录片编导</span></div></div>
          </div>
        </div>
      </div>
      <!-- 输出参数（条数 / 清晰度 / 比例） -->
      <div class="relative shrink-0" id="video-output-params-wrap">
        <button type="button" onclick="toggleVideoOutputParamsDropdown(event)" class="text-[10px] px-2.5 py-1 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700/50 hover:bg-gray-100 dark:hover:bg-gray-600 transition flex items-center gap-1.5 text-gray-700 dark:text-gray-200">
          <svg class="shrink-0 text-gray-500 dark:text-gray-400" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
          <span id="video-output-params-label" class="whitespace-nowrap">1:1 / 480p / 4秒 / 无配音</span>
          <svg class="shrink-0 text-gray-400" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div id="video-output-params-dropdown" class="hidden absolute bottom-full left-0 mb-1 w-[300px] video-output-panel shadow-2xl overflow-hidden z-50 max-h-[70vh] overflow-y-auto">
          <div class="px-3 pt-3 pb-2 border-b border-gray-700/80">
            <div class="vop-section-title">视频比例</div>
            <div class="grid grid-cols-7 gap-1">
              <button type="button" onclick="setVideoOutputParam('ratio','Auto')" data-vparam="ratio" data-vvalue="Auto" class="video-ratio-opt flex flex-col items-center gap-0.5 py-1.5 text-[9px]"><span class="w-4 h-3 border border-current rounded-[2px] opacity-70"></span>Auto</button>
              <button type="button" onclick="setVideoOutputParam('ratio','16:9')" data-vparam="ratio" data-vvalue="16:9" class="video-ratio-opt flex flex-col items-center gap-0.5 py-1.5 text-[9px]"><span class="w-5 h-2.5 border border-current rounded-[2px]"></span>16:9</button>
              <button type="button" onclick="setVideoOutputParam('ratio','4:3')" data-vparam="ratio" data-vvalue="4:3" class="video-ratio-opt flex flex-col items-center gap-0.5 py-1.5 text-[9px]"><span class="w-4 h-3 border border-current rounded-[2px]"></span>4:3</button>
              <button type="button" onclick="setVideoOutputParam('ratio','1:1')" data-vparam="ratio" data-vvalue="1:1" class="video-ratio-opt flex flex-col items-center gap-0.5 py-1.5 text-[9px]"><span class="w-3.5 h-3.5 border border-current rounded-[2px]"></span>1:1</button>
              <button type="button" onclick="setVideoOutputParam('ratio','3:4')" data-vparam="ratio" data-vvalue="3:4" class="video-ratio-opt flex flex-col items-center gap-0.5 py-1.5 text-[9px]"><span class="w-3 h-4 border border-current rounded-[2px]"></span>3:4</button>
              <button type="button" onclick="setVideoOutputParam('ratio','9:16')" data-vparam="ratio" data-vvalue="9:16" class="video-ratio-opt flex flex-col items-center gap-0.5 py-1.5 text-[9px]"><span class="w-2.5 h-5 border border-current rounded-[2px]"></span>9:16</button>
              <button type="button" onclick="setVideoOutputParam('ratio','21:9')" data-vparam="ratio" data-vvalue="21:9" class="video-ratio-opt flex flex-col items-center gap-0.5 py-1.5 text-[9px]"><span class="w-6 h-2 border border-current rounded-[2px]"></span>21:9</button>
            </div>
          </div>
          <div class="px-3 py-2 border-b border-gray-700/80">
            <div class="vop-section-title">视频质量</div>
            <div class="grid grid-cols-3 gap-1.5">
              <button type="button" onclick="setVideoOutputParam('quality','480p')" data-vparam="quality" data-vvalue="480p" class="video-quality-opt text-[10px] py-1.5">480p</button>
              <button type="button" onclick="setVideoOutputParam('quality','720p')" data-vparam="quality" data-vvalue="720p" class="video-quality-opt text-[10px] py-1.5">720p</button>
              <button type="button" onclick="setVideoOutputParam('quality','native1080p')" data-vparam="quality" data-vvalue="native1080p" class="video-quality-opt text-[10px] py-1.5">native1080p</button>
              <button type="button" onclick="setVideoOutputParam('quality','1080p')" data-vparam="quality" data-vvalue="1080p" class="video-quality-opt text-[10px] py-1.5">1080p</button>
              <button type="button" onclick="setVideoOutputParam('quality','2k')" data-vparam="quality" data-vvalue="2k" class="video-quality-opt text-[10px] py-1.5">2k</button>
              <button type="button" onclick="setVideoOutputParam('quality','4k')" data-vparam="quality" data-vvalue="4k" class="video-quality-opt text-[10px] py-1.5">4k</button>
            </div>
          </div>
          <div class="px-3 py-2 border-b border-gray-700/80">
            <div class="vop-section-title">视频时长</div>
            <div class="flex items-center gap-2">
              <input type="range" id="video-duration-slider" class="video-duration-slider flex-1" min="2" max="16" step="1" value="4" oninput="setVideoDuration(this.value)">
              <span id="video-duration-display" class="text-[11px] text-gray-300 bg-[#2a2a2a] border border-gray-600 rounded px-2 py-0.5 min-w-[40px] text-center">4秒</span>
            </div>
          </div>
          <div class="px-3 py-2 pb-3">
            <div class="vop-section-title">生成音频</div>
            <div class="flex">
              <button type="button" onclick="setVideoToggleParam('audio','开启')" data-vtoggle="audio" data-vvalue="开启" class="video-toggle-opt">开启</button>
              <button type="button" onclick="setVideoToggleParam('audio','关闭')" data-vtoggle="audio" data-vvalue="关闭" class="video-toggle-opt">关闭</button>
            </div>
          </div>
        </div>
        <select id="video-param-count" class="hidden" aria-hidden="true"><option selected>1条</option><option>2条</option><option>4条</option></select>
        <select id="video-param-quality" class="hidden" aria-hidden="true"><option>480p</option><option>720p</option><option>native1080p</option><option>1080p</option><option>2k</option><option>4k</option></select>
        <select id="video-param-ratio" class="hidden" aria-hidden="true"><option>Auto</option><option>16:9</option><option>4:3</option><option selected>1:1</option><option>3:4</option><option>9:16</option><option>21:9</option></select>
        <input type="hidden" id="video-param-duration" value="4">
        <input type="hidden" id="video-param-realperson" value="关闭">
        <input type="hidden" id="video-param-audio" value="关闭">
      </div>
      <!-- 生成模式（多模式参考 / 首尾帧） -->
      <div class="relative shrink-0" id="video-mode-dropdown-container">
        <button type="button" onclick="toggleVideoModeDropdown(event)" class="text-[10px] px-2 py-1 rounded-lg border border-gray-200 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 transition flex items-center gap-1.5 bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-300">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
          <span id="current-video-mode-text" class="whitespace-nowrap">多模式参考</span>
          <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div id="video-mode-dropdown" class="hidden absolute bottom-full left-0 mb-1 w-44 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-lg overflow-hidden z-50">
          <div class="px-3 py-2 text-[10px] text-gray-400 border-b border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">🎬 生成模式</div>
          <div class="py-1">
            <div onclick="selectVideoParamMode('多模式参考')" data-mode-opt="多模式参考" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer text-[11px]">多模式参考</div>
            <div onclick="selectVideoParamMode('首尾帧')" data-mode-opt="首尾帧" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer text-[11px]">首尾帧</div>
          </div>
        </div>
      </div>
      <select id="video-param-mode" class="hidden" aria-hidden="true"><option selected>多模式参考</option><option>首尾帧</option></select>
      <span id="video-gen-cost" class="text-[11px] font-medium px-2 py-1 bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-lg border border-blue-100 dark:border-blue-800 shrink-0 whitespace-nowrap inline-flex items-center gap-0.5">💰 预估: <span class="text-yellow-500 leading-none" aria-hidden="true">⚡</span>0.0003</span>
      <div class="flex-1"></div>
      <button type="button" id="video-gen-btn-desktop" onclick="startVideoGeneration()" class="gen-btn px-4 py-1 bg-gradient-to-r from-blue-500 to-purple-600 text-white text-xs font-semibold rounded-lg hover:from-blue-600 hover:to-purple-700 transition">✨ 生成</button>
      </div>
    </div>
    </div>
  </div>
  <!-- 素材放大预览弹窗 -->
  <div id="video-preview-modal" onclick="if(event.target===this)closeVideoPreview()" class="hidden fixed inset-0 z-[100] bg-black/80 backdrop-blur-sm items-center justify-center">
    <div class="relative flex flex-col items-center max-w-[90vw] max-h-[90vh]">
      <button onclick="closeVideoPreview()" class="absolute -top-10 right-0 text-white/70 hover:text-white text-2xl transition">&times;</button>
      <div id="video-preview-name" class="text-white/70 text-xs mb-3 truncate max-w-full"></div>
      <div id="video-preview-content" class="flex items-center justify-center"></div>
    </div>
  </div>
</section>

    <section id="page-audio" class="page-section relative">
  <!-- 音频结果展示区 -->
  <div id="audio-canvas-area" class="relative z-0 bg-gradient-to-br from-gray-100 to-gray-200 dark:from-gray-800 dark:to-gray-700 flex items-start justify-center overflow-auto">
    <div id="audio-empty-state" class="hidden absolute inset-0 flex items-center justify-center pointer-events-none z-0">
      <div class="text-center text-gray-400 text-sm w-full max-w-xl px-6">
        <div class="w-full h-36 bg-white/40 dark:bg-gray-900/30 backdrop-blur rounded-2xl border border-gray-200/60 dark:border-gray-600/60 flex items-center justify-center mb-4 shadow-sm">
          <div class="text-center">
            <div class="text-4xl mb-2">🔊</div>
            <div class="text-[11px] text-gray-500 dark:text-gray-400">音频波形可视化</div>
            <div class="text-[11px] mt-2 font-mono tabular-nums">▶ 0:00 / 0:00</div>
          </div>
        </div>
        <div>生成的音频将显示在这里</div>
      </div>
    </div>
    <div id="audio-hot-apps-slot" class="audio-hot-apps-slot">
      <div id="audio-hot-apps-mount" class="w-full max-w-3xl"></div>
      <div id="audio-empty-inline" class="w-full max-w-xl text-center text-gray-400 dark:text-gray-500 text-xs py-2 mb-1 px-4">
        <div class="w-full h-28 mx-auto bg-white/40 dark:bg-gray-900/30 backdrop-blur rounded-2xl border border-gray-200/60 dark:border-gray-600/60 flex items-center justify-center mb-3 shadow-sm">
          <div class="text-center">
            <div class="text-3xl mb-1">🔊</div>
            <div class="text-[10px] text-gray-500 dark:text-gray-400">输入文本并选择音色，开始语音创作</div>
          </div>
        </div>
      </div>
    </div>
    <div id="audio-results-container" class="hidden flex flex-col items-center w-full max-w-5xl mx-auto px-4 pt-4 gap-6 pb-4 relative z-[1]">
      <div id="audio-generating-state" class="hidden w-full bg-white/80 dark:bg-gray-800/80 backdrop-blur rounded-2xl shadow-lg p-4 scroll-mt-4">
        <div class="flex items-center gap-2 mb-3 text-[11px] text-amber-600 dark:text-amber-400 font-medium">
          <span class="inline-block w-2 h-2 rounded-full bg-amber-500 animate-pulse"></span>
          <span>生成中</span>
        </div>
        <div class="w-full flex flex-wrap items-center gap-x-3 gap-y-1 mb-3 text-[11px] text-gray-600 dark:text-gray-400">
          <span id="audio-gen-voice" class="px-2 py-0.5 bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded text-[10px] font-medium shrink-0">默认音色</span>
          <span id="audio-gen-model" class="shrink-0">Auto</span>
          <span class="text-gray-300 dark:text-gray-600">|</span>
          <span id="audio-gen-params" class="shrink-0">1.0x / 标准 / 无</span>
          <span class="text-gray-300 dark:text-gray-600">|</span>
          <span id="audio-gen-quality" class="shrink-0">Turbo</span>
        </div>
        <p id="audio-gen-prompt" class="result-prompt-text text-gray-700 dark:text-gray-300 mb-4 text-[12px] w-full"><span class="result-prompt-body"></span><span class="result-prompt-toggle-hint hidden"></span></p>
        <div class="rounded-xl border border-dashed border-gray-200 dark:border-gray-600 bg-gray-50/80 dark:bg-gray-900/40 p-6">
          <div class="w-full flex items-center gap-3">
            <div class="flex-1 h-2 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
              <div id="audio-gen-progress-bar" class="h-full bg-gradient-to-r from-blue-500 to-purple-500 rounded-full transition-all duration-300" style="width:0%"></div>
            </div>
            <span id="audio-gen-status-text" class="text-[12px] text-gray-500 dark:text-gray-400 whitespace-nowrap tabular-nums">0%</span>
          </div>
          <div class="text-[12px] text-gray-500 dark:text-gray-400 mt-2"><span id="audio-gen-status-detail">正在准备任务...</span></div>
        </div>
      </div>
    </div>
  </div>

  <!-- 浮动输入框（音色 + 文本 + 工具栏） -->
  <div id="audio-input-area" class="pointer-events-auto">
    <div class="bg-white/95 dark:bg-gray-800/95 backdrop-blur border border-gray-200 dark:border-gray-700 rounded-2xl shadow-lg">
      <div id="audio-voice-bar" class="audio-voice-bar">
        <div class="audio-voice-bar-mobile hidden">
          <div class="media-tool-icons">
            <button type="button" class="media-tool-icon new-voice" title="新建音色" aria-label="新建音色">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>
            </button>
            <button type="button" id="audio-m-icon-voice" class="media-tool-icon" title="选择音色" onclick="openVoicePickerModal()">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </button>
            <button type="button" class="media-tool-icon" title="资产导入" onclick="openAudioAssetModal()">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
            </button>
          </div>
        </div>
        <div class="audio-voice-bar-desktop flex items-center gap-2 flex-wrap px-4 pt-2.5 pb-2 border-b border-gray-100 dark:border-gray-700">
          <button type="button" class="new-voice text-[11px] px-3 py-1.5 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition shrink-0">🎤 新建音色</button>
          <button type="button" id="audio-voice-picker-btn" onclick="openVoicePickerModal()" class="audio-voice-picker-btn" title="选择音色">
            <span id="audio-voice-picker-avatar" class="audio-voice-picker-btn-avatar" aria-hidden="true">音</span>
            <span id="audio-voice-picker-label" class="audio-voice-picker-btn-label truncate">选择音色</span>
            <svg class="shrink-0 text-gray-400" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <button type="button" onclick="openAudioAssetModal()" class="audio-asset-import-btn shrink-0 inline-flex items-center gap-1 text-[11px] px-2.5 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition" title="从资产库导入">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
            <span class="whitespace-nowrap">资产导入</span>
          </button>
        </div>
        <input type="hidden" id="audio-selected-voice" value="">
        <input type="hidden" id="audio-selected-voice-id" value="">
        <select id="voice-select" class="hidden" aria-hidden="true" tabindex="-1"><option value="">选择音色</option></select>
      </div>
      <!-- 手机端：情绪表情条（紧贴输入框上方） -->
      <div id="audio-mobile-emotion-bar" class="hidden px-4 pt-1.5 pb-0 border-t border-gray-100 dark:border-gray-700">
        <div id="audio-mobile-emotion-content" class="flex flex-wrap gap-1.5">
          <!-- 由 JS 动态渲染 -->
        </div>
        <button type="button" id="audio-mobile-emotion-toggle" class="hidden w-full text-center text-[10px] text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 py-0.5 mt-0.5" onclick="toggleAudioMobileEmotionBarExpand()">
          <svg class="inline-block w-3.5 h-3.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        </button>
      </div>
      <div class="px-4 pt-2.5 pb-2">
        <textarea id="audio-prompt-textarea" placeholder="输入想要朗读的文本内容..." class="w-full text-xs border-0 bg-transparent outline-none resize-none leading-relaxed" rows="5"></textarea>
