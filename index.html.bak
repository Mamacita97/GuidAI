        <div class="flex items-center gap-2">
          <input id="new-key-value" readonly value="sk-guid-abc123def456ghi789jkl012mno345pqr678stu" class="flex-1 text-xs font-mono border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2.5 bg-gray-50 dark:bg-gray-700 select-all">
          <button class="copy-new-key-btn px-3 py-2.5 text-xs bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition whitespace-nowrap" onclick="copyNewKey()">📋 复制</button>
