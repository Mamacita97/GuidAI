        <button id="wd-use-btn" onclick="pressAnim(this);showPage('image');showToast('🚀 已跳转图片页面')" class="w-full py-2.5 rounded-xl bg-gradient-to-r from-green-500 to-emerald-500 text-white text-xs font-semibold hover:from-green-600 hover:to-emerald-600 transition">🚀 免费使用此灵感</button>
      </div>

      <!-- 创作者 -->
      <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-3 cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-700 transition" onclick="showToast('👤 跳转创作者主页')">
        <div class="flex justify-between"><span class="text-[10px] text-gray-500">创作者</span><span class="text-[10px] text-gray-500">本月收益</span></div>
        <div class="flex justify-between"><span class="text-xs font-semibold" id="wd-creator">青铜娃娃</span><span class="text-xs font-semibold text-purple-600">⚡234</span></div>
      </div>

      <!-- 相关推荐 -->
      <div>
        <div class="flex items-center gap-2 mb-3"><div class="h-px flex-1 bg-gray-200 dark:bg-gray-700"></div><span class="text-[11px] font-semibold text-gray-400 shrink-0">相关推荐</span><div class="h-px flex-1 bg-gray-200 dark:bg-gray-700"></div></div>
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 rounded-xl overflow-hidden cursor-pointer hover:shadow-md transition" onclick="showToast('📂 打开作品详情')">
            <div class="aspect-square bg-gradient-to-br from-purple-300 to-blue-300 dark:from-purple-700 dark:to-blue-700 flex items-center justify-center text-white text-xs">相关1</div>
            <div class="p-2"><div class="text-[10px] font-medium truncate">霓虹都市·赛博朋克</div><div class="text-[9px] text-gray-400">987次使用</div></div>
          </div>
          <div class="bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 rounded-xl overflow-hidden cursor-pointer hover:shadow-md transition" onclick="showToast('📂 打开作品详情')">
            <div class="aspect-square bg-gradient-to-br from-indigo-300 to-purple-300 dark:from-indigo-700 dark:to-purple-700 flex items-center justify-center text-white text-xs">相关2</div>
            <div class="p-2"><div class="text-[10px] font-medium truncate">数字流体艺术</div><div class="text-[9px] text-gray-400">1.8k次使用</div></div>
