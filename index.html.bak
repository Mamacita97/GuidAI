      <div>
        <div class="text-[11px] text-gray-500 mb-1.5">密钥名称</div>
        <input id="new-key-name" placeholder="例如：我的应用-生产" class="w-full text-xs border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2.5 focus:border-blue-500 focus:outline-none bg-white dark:bg-gray-800">
