        <div class="text-[9px] text-gray-400 mt-1">支持 jpg/png，≤10MB</div>
      </div>
    </div>
    <button type="button" onclick="showToast('📁 从资产库选择素材')" class="w-full mt-2 text-[11px] px-3 py-1.5 border border-gray-200 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition">从资产库选择</button>
  </div>
  <button type="button" onclick="startAppDetailGenerate()" class="w-full py-2.5 bg-gradient-to-r from-purple-600 to-blue-600 text-white text-xs font-semibold rounded-xl hover:from-purple-700 hover:to-blue-700 transition mb-3">✨ 立即生成</button>
