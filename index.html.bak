            <span>📁 历史对话</span>
            <button onclick="toggleHistoryDropdown()" class="text-gray-400 hover:text-gray-600">✕</button>
          </div>
          <div class="py-1 max-h-72 overflow-y-auto">
            <!-- 今天 -->
            <div class="px-3 py-1 text-[10px] text-gray-400 bg-gray-50 dark:bg-gray-800/50">📅 今天</div>
            <div onclick="loadHistoryChat('chat-1')" class="history-item px-3 py-2 hover:bg-blue-50 dark:hover:bg-blue-900/20 cursor-pointer border-b border-gray-50 dark:border-gray-700/50">
