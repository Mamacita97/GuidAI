      <div class="flex flex-wrap items-center gap-2 mt-2 text-[10px]">
        <span class="px-2 py-0.5 rounded-full bg-red-50 dark:bg-red-900/25 text-red-500" id="apd-heat">🔥 52.3k</span>
        <span class="text-gray-400" id="apd-rating">👍 4.9</span>
        <span class="text-gray-400" id="apd-uses">📊 52.3k次使用</span>
      </div>
    </div>
    <button type="button" id="apd-fav-btn" onclick="toggleAppDetailFav()" class="text-xl text-gray-400 hover:text-yellow-500 shrink-0" title="收藏">☆</button>
  </div>
  <div class="apd-preview mb-5" id="apd-preview">
    <div class="w-28 h-28 bg-gradient-to-br from-gray-200 to-gray-300 dark:from-gray-700 dark:to-gray-600 rounded-lg flex items-center justify-center text-gray-400 text-[10px]">原图</div>
    <div class="text-lg text-gray-400">→</div>
    <div class="w-28 h-28 bg-gradient-to-br from-purple-200 to-blue-200 dark:from-purple-800/30 dark:to-blue-800/30 rounded-lg flex items-center justify-center text-gray-400 text-[10px]">生成效果</div>
  </div>
  <div class="mb-4">
    <div class="flex items-center gap-2 mb-2"><div class="h-px flex-1 bg-gray-200 dark:bg-gray-700"></div><span class="text-[11px] font-semibold text-gray-400 shrink-0">功能说明</span><div class="h-px flex-1 bg-gray-200 dark:bg-gray-700"></div></div>
    <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-3 text-[11px] text-gray-600 dark:text-gray-400 leading-relaxed" id="apd-long-desc"></div>
  </div>
  <div class="mb-4">
    <div class="flex items-center gap-2 mb-2"><div class="h-px flex-1 bg-gray-200 dark:bg-gray-700"></div><span class="text-[11px] font-semibold text-gray-400 shrink-0">价格信息</span><div class="h-px flex-1 bg-gray-200 dark:bg-gray-700"></div></div>
    <div class="flex gap-4 text-xs bg-gray-50 dark:bg-gray-800 rounded-lg p-3">
      <span>使用价格：<span class="text-purple-600 font-semibold" id="apd-price">⚡0.5/次</span></span>
      <span class="text-gray-400">|</span>
      <span>当前余额：⚡12.50</span>
    </div>
  </div>
  <div class="mb-4">
    <div class="flex items-center gap-2 mb-2"><div class="h-px flex-1 bg-gray-200 dark:bg-gray-700"></div><span class="text-[11px] font-semibold text-gray-400 shrink-0">素材上传</span><div class="h-px flex-1 bg-gray-200 dark:bg-gray-700"></div></div>
    <div class="flex gap-3">
      <div class="flex-1 border-2 border-dashed border-gray-300 dark:border-gray-600 rounded-xl p-3 text-center cursor-pointer hover:border-blue-400 transition">
        <div class="text-lg mb-1">📷</div>
