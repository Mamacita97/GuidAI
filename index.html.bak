              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>
            </button>
            <button type="button" id="audio-m-icon-quality" class="media-tool-icon" title="质量" onclick="openAudioMobileSheet('quality',event)">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </button>
            <button type="button" id="audio-m-icon-emotion" class="media-tool-icon" title="情绪" onclick="openAudioMobileSheet('emotion',event)">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
            </button>
            <button type="button" id="audio-m-icon-voice-in" class="media-tool-icon mobile-voice-btn" title="语音输入" data-voice-input="audio-prompt-textarea" onclick="toggleMobileVoiceInput(event)">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
            </button>
          </div>
          <button type="button" id="audio-gen-btn-mobile" onclick="startAudioGeneration()" class="media-gen-btn gen-btn px-3 py-1.5 bg-gradient-to-r from-blue-500 to-purple-600 text-white text-xs font-semibold rounded-xl hover:from-blue-600 hover:to-purple-700 transition">✨ 生成</button>
        </div>
        <div class="audio-toolbar-desktop flex flex-wrap items-center gap-2 w-full">
