    <div class="flex items-center gap-1 mb-3">
      <button class="asset-tab text-[11px] px-3 py-1.5 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-600 cursor-pointer" data-tab="image" onclick="switchAssetTab('image',this)">📷 图片</button>
      <button class="asset-tab text-[11px] px-3 py-1.5 rounded-full bg-gray-100 dark:bg-gray-800 cursor-pointer hover:bg-gray-200 dark:hover:bg-gray-700" data-tab="video" onclick="switchAssetTab('video',this)">🎬 视频</button>
      <button class="asset-tab text-[11px] px-3 py-1.5 rounded-full bg-gray-100 dark:bg-gray-800 cursor-pointer hover:bg-gray-200 dark:hover:bg-gray-700" data-tab="text" onclick="switchAssetTab('text',this)">📝 文本</button>
      <button class="asset-tab text-[11px] px-3 py-1.5 rounded-full bg-gray-100 dark:bg-gray-800 cursor-pointer hover:bg-gray-200 dark:hover:bg-gray-700" data-tab="audio" onclick="switchAssetTab('audio',this)">🎵 音频</button>
    </div>

    <!-- 本地上传 -->
    <div id="asset-upload-zone" onclick="triggerAssetUpload()" class="mb-3 border-2 border-dashed border-gray-200 dark:border-gray-600 rounded-xl p-4 text-center cursor-pointer hover:border-blue-400 hover:bg-blue-50/50 dark:hover:bg-blue-900/10 transition">
      <input type="file" id="asset-upload-input" class="hidden" multiple onchange="handleAssetUpload(this)">
      <div class="text-2xl mb-1">📤</div>
      <div class="text-[11px] text-gray-600 dark:text-gray-300 font-medium">点击此处上传</div>
      <div id="asset-upload-hint" class="text-[10px] text-gray-400 mt-1">支持 JPG / PNG / WebP 等图片</div>
    </div>
    <div id="asset-upload-progress" class="hidden mb-3">
      <div class="flex items-center justify-between text-[10px] text-gray-500 mb-1"><span id="asset-upload-status">上传中...</span><span id="asset-upload-pct">0%</span></div>
      <div class="w-full h-1.5 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden"><div id="asset-upload-bar" class="h-full bg-blue-500 rounded-full transition-all" style="width:0%"></div></div>
    </div>

    <!-- 搜索 -->
