        <!-- 附件预览区域 -->
        <div id="chat-attachments-area" class="hidden flex flex-wrap gap-2 px-4 pt-3">
          <!-- 附件缩略图将动态插入到这里 -->
        </div>
        <!-- 隐藏的文件输入框 -->
        <input type="file" id="chat-file-input" class="hidden" multiple accept="image/*,.pdf,.doc,.docx,.txt,.mp3,.wav,.ogg,.m4a,.pptx,.xlsx,.zip" onchange="handleChatFileSelect(this)">
        <!-- 输入框 -->
        <div class="px-4 pt-2.5 pb-2">
          <div class="flex items-center gap-0.5 mb-1.5">
            <button type="button" onclick="document.getElementById('chat-file-input').click()" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 p-1 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700/80 transition" title="上传附件"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg></button>
            <button type="button" data-open-asset-modal onclick="openChatAssetModal()" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 p-1 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700/80 transition" title="从我的资产库添加"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg></button>
            <button type="button" class="save-asset text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 p-1 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700/80 transition" title="将当前内容保存为文本资产"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg></button>
          </div>
          <textarea placeholder="输入问题或指令…" rows="2" class="w-full bg-transparent outline-none text-xs sm:text-xs resize-none leading-relaxed chat-input-field" id="chat-input"></textarea>
        </div>
