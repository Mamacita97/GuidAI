            <span class="font-medium">default分组</span>
            <span class="text-gray-400">按量计费</span>
            <span class="model-detail-def-price text-green-600 inline-flex items-center gap-0.5"><span class="text-yellow-500 leading-none" aria-hidden="true">⚡</span>75.0000</span>
          </div>
          <div class="flex items-center justify-between text-xs p-1.5">
            <span class="font-medium">vip分组</span>
            <span class="text-gray-400">按量计费</span>
            <span class="model-detail-vip-price text-green-600 inline-flex items-center gap-0.5"><span class="text-yellow-500 leading-none" aria-hidden="true">⚡</span>150.0000</span>
