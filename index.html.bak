                    <div class="text-[9px] text-gray-400 mt-0.5 ml-6 inline-flex items-center gap-0.5"><span class="text-yellow-500 leading-none" aria-hidden="true">⚡</span>0.50 / 1M tokens</div>
                  </div>
                  <div onclick="selectChatModel('Gemini 2.5 Pro','✨')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer">
