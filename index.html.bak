  <div class="flex flex-col md:flex-row gap-5">
    <!-- 左侧导航 -->
    <div class="md:w-56 shrink-0">
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-3 sticky top-20">
        <div class="relative mb-3">
          <input class="mcp-search w-full text-[10px] border border-gray-200 dark:border-gray-600 rounded-lg px-2.5 py-1.5 bg-gray-50 dark:bg-gray-700 focus:outline-none focus:border-blue-500" placeholder="🔍 搜索文档...">
        </div>
        <div class="space-y-0.5 text-xs">
          <div class="text-[10px] text-gray-400 font-medium px-2 py-1">📌 快速开始</div>
          <div class="mcp-nav-item active px-2 py-1.5 rounded-lg cursor-pointer bg-blue-50 dark:bg-blue-900/20 text-blue-600" data-section="intro">简介</div>
          <div class="mcp-nav-item px-2 py-1.5 rounded-lg cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700/30" data-section="setup" onclick="scrollToSection('setup')">安装配置</div>
          <div class="mcp-nav-item px-2 py-1.5 rounded-lg cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700/30" data-section="first" onclick="scrollToSection('first')">第一个请求</div>
          <div class="border-t border-gray-100 dark:border-gray-700 my-1"></div>
          <div class="text-[10px] text-gray-400 font-medium px-2 py-1">🔌 API参考</div>
          <div class="mcp-nav-item px-2 py-1.5 rounded-lg cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700/30" data-section="chat-api" onclick="scrollToSection('chat-api')">对话API</div>
          <div class="mcp-nav-item px-2 py-1.5 rounded-lg cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700/30" data-section="image-api" onclick="scrollToSection('image-api')">图像API</div>
          <div class="mcp-nav-item px-2 py-1.5 rounded-lg cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700/30" data-section="video-api" onclick="scrollToSection('video-api')">视频API</div>
          <div class="mcp-nav-item px-2 py-1.5 rounded-lg cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700/30" data-section="audio-api" onclick="scrollToSection('audio-api')">音频API</div>
          <div class="border-t border-gray-100 dark:border-gray-700 my-1"></div>
          <div class="text-[10px] text-gray-400 font-medium px-2 py-1">🛠️ SDK与工具</div>
          <div class="mcp-nav-item px-2 py-1.5 rounded-lg cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700/30" data-section="python-sdk" onclick="scrollToSection('python-sdk')">Python SDK</div>
          <div class="mcp-nav-item px-2 py-1.5 rounded-lg cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700/30" data-section="js-sdk" onclick="scrollToSection('js-sdk')">JavaScript SDK</div>
