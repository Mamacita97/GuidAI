            <div onclick="loadHistoryChat('chat-3')" class="history-item px-3 py-2 hover:bg-blue-50 dark:hover:bg-blue-900/20 cursor-pointer border-b border-gray-50 dark:border-gray-700/50">
              <div class="text-[11px] font-medium text-gray-700 dark:text-gray-300 truncate">翻译这段英文技术文档</div>
              <div class="text-[9px] text-gray-400 mt-0.5">1小时前 · DeepSeek V3</div>
            </div>
