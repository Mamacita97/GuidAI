<!-- ===== 音色克隆弹窗 ===== -->
<div class="modal-overlay" id="voice-clone-modal">
  <div class="modal-content p-5" style="max-width:480px">
    <div class="flex items-center justify-between mb-2"><span class="text-base font-bold">🎤 新建音色</span><button onclick="closeModal('voice-clone-modal')" class="text-gray-400 text-xl">×</button></div>
    <div class="text-[11px] text-gray-400 mb-3">上传或录制音频，AI 将克隆你的专属音色，首次激活后永久有效</div>
    <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-3 text-[11px] text-blue-700 dark:text-blue-300 mb-4 space-y-0.5">
      <div>💡 • 请上传清晰的人声录音，背景噪音越小效果越好</div>
      <div>&nbsp;&nbsp;• 建议音频时长 10-60 秒，效果最佳</div>
      <div>&nbsp;&nbsp;• 支持格式：MP3、WAV、AAC、M4A</div>
      <div>&nbsp;&nbsp;• 首次激活后永久有效，可在「选择音色」中随时使用</div>
    </div>
    <div id="voice-source-row" class="voice-source-row">
      <div id="voice-upload-area" class="voice-source-card" onclick="startVoiceUpload()">
        <div class="text-4xl mb-2">📁</div>
        <div class="text-sm font-medium mb-1">点击上传音频</div>
        <div class="text-[10px] text-gray-400">MP3 / WAV / AAC / M4A<br>建议 10-60 秒</div>
      </div>
      <div class="voice-source-card voice-record-card">
        <button type="button" id="voice-record-btn" onclick="toggleVoiceCloneRecording(event)">
          <div id="voice-record-icon" class="text-4xl mb-2">🎙️</div>
          <div id="voice-record-label" class="text-sm font-medium mb-1">点击开始录音</div>
          <div id="voice-record-hint" class="text-[10px] text-gray-400">使用麦克风录制<br>建议 10-60 秒</div>
          <div id="voice-record-timer" class="voice-record-timer hidden">00:00</div>
        </button>
      </div>
    </div>
    <div id="voice-upload-progress" class="hidden mb-4">
      <div class="flex items-center justify-between text-xs mb-1"><span>⏳ 上传中...</span><span id="voice-upload-pct">0%</span></div>
      <div class="w-full h-2 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden"><div id="voice-upload-bar" class="h-full bg-blue-500 rounded-full transition-all" style="width:0%"></div></div>
      <div class="text-[10px] text-gray-400 mt-1" id="voice-upload-name">正在上传音频文件...</div>
    </div>
    <div id="voice-upload-done" class="hidden mb-4">
      <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-3 mb-3"><div class="text-xs font-semibold text-green-700 dark:text-green-300">✅ 上传成功</div><div class="text-[10px] text-gray-500 mt-0.5" id="voice-file-info">文件：my_voice.mp3 ｜ 时长：00:00:35</div></div>
      <div class="h-12 bg-gray-100 dark:bg-gray-800 rounded-lg flex items-center justify-center text-gray-400 text-xs"><span>🔊 音频波形预览  ▶ 0:00 / 0:35</span></div>
    </div>
    <div class="mb-4"><div class="text-[11px] text-gray-500 mb-1">音色名称（选填）</div><input id="voice-name-input" placeholder="例如：我的专属音色" class="w-full text-xs border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2 focus:border-blue-500 focus:outline-none bg-white dark:bg-gray-800"></div>
    <div id="voice-clone-progress" class="hidden mb-4">
      <div class="flex items-center justify-between text-xs mb-1"><span>⏳ AI正在克隆你的音色...</span><span id="voice-clone-pct">0%</span></div>
      <div class="w-full h-2 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden"><div id="voice-clone-bar" class="h-full bg-purple-500 rounded-full transition-all" style="width:0%"></div></div>
      <div class="text-[10px] text-gray-400 mt-1" id="voice-clone-status">正在分析音频特征...</div>
    </div>
    <div id="voice-clone-success" class="hidden mb-4">
      <div class="bg-purple-50 dark:bg-purple-900/20 border border-purple-200 dark:border-purple-800 rounded-xl p-4"><div class="text-center mb-3"><div class="text-3xl mb-1">✅</div><div class="text-sm font-bold">音色克隆成功！</div><div class="text-[10px] text-gray-500 mt-0.5" id="voice-clone-name-display">音色名称：我的专属音色</div></div><div class="h-10 bg-gray-100 dark:bg-gray-800 rounded-lg flex items-center justify-center text-gray-400 text-xs cursor-pointer hover:bg-gray-200" onclick="showToast('🔊 播放试听')">🔊 试听克隆音色  ▶ 0:00 / 0:05</div><div class="text-[9px] text-gray-400 mt-2 text-center">"你好，这是AI克隆的声音效果"</div><div class="text-[10px] text-blue-600 mt-2 text-center">💡 音色已保存，可在「选择音色」中随时使用</div></div>
    </div>
    <div class="text-[10px] text-amber-600 mb-4">⚠️ 克隆的音色仅限本人使用，请勿上传他人音频</div>
    <button type="button" id="voice-start-clone" onclick="startVoiceClone()" class="w-full py-2 text-xs bg-gradient-to-r from-purple-500 to-blue-500 text-white font-semibold rounded-lg hover:from-purple-600 hover:to-blue-600">开始克隆</button>
  </div>
</div>

<!-- ===== 选择音色弹窗 ===== -->
<div class="modal-overlay" id="voice-picker-modal">
  <div class="modal-content">
    <div class="voice-picker-head">
      <span class="text-base font-bold text-gray-900 dark:text-white">选择音色</span>
      <button type="button" onclick="closeModal('voice-picker-modal')" class="text-gray-400 hover:text-gray-600 text-xl leading-none w-8 h-8 flex items-center justify-center" aria-label="关闭">×</button>
    </div>
    <div id="voice-picker-filters-wrap" class="voice-picker-filters-wrap">
      <div id="voice-picker-filters" class="voice-picker-filters"></div>
    </div>
    <button type="button" id="voice-picker-collapse-btn" class="voice-picker-collapse" onclick="toggleVoicePickerFilters()">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 15l-6-6-6 6"/></svg>
      <span id="voice-picker-collapse-text">收起</span>
    </button>
    <div class="voice-picker-body">
      <div id="voice-picker-grid" class="voice-picker-grid"></div>
    </div>
  </div>
</div>

<!-- ===== 法律信息弹窗 ===== -->
<div class="modal-overlay" id="legal-modal">
  <div class="modal-content p-5" style="max-width:520px">
    <div class="flex items-center justify-between mb-3">
      <span class="text-base font-bold">📄 用户协议</span>
      <button onclick="closeModal('legal-modal')" class="text-gray-400 hover:text-gray-600 text-xl leading-none">×</button>
    </div>
    <div class="space-y-4 text-xs leading-relaxed text-gray-600 dark:text-gray-400 max-h-80 overflow-y-auto">
      <div><strong class="text-gray-800 dark:text-gray-200">1. 服务说明</strong><br>GUID.AI是一个AI大模型聚合平台，为用户提供AI聊天、图片生成、视频生成、音频生成等服务。</div>
      <div><strong class="text-gray-800 dark:text-gray-200">2. 账户注册</strong><br>用户使用手机号或邮箱验证码登录即自动注册，无需单独注册流程。</div>
      <div><strong class="text-gray-800 dark:text-gray-200">3. 积分与支付</strong><br>平台使用⚡算力作为积分单位，充值比例为¥1=⚡1。积分永久有效，不可转让。</div>
      <div><strong class="text-gray-800 dark:text-gray-200">4. 用户行为规范</strong><br>用户不得使用平台服务从事违法违规活动，不得利用AI生成违反法律法规的内容。</div>
      <div><strong class="text-gray-800 dark:text-gray-200">5. 知识产权</strong><br>用户使用平台生成的内容，知识产权归用户所有。平台不对用户生成内容的合法性承担责任。</div>
      <div><strong class="text-gray-800 dark:text-gray-200">6. 免责声明</strong><br>平台按"现状"提供服务，不对服务的连续性、及时性、安全性做任何明示或默示的保证。</div>
      <div><strong class="text-gray-800 dark:text-gray-200">7. 协议修改</strong><br>平台有权根据需要修改本协议，修改后的协议一经发布即生效。</div>
    </div>
    <div class="flex justify-end mt-4 pt-3 border-t border-gray-100 dark:border-gray-700">
      <button onclick="closeModal('legal-modal')" class="px-5 py-2 text-xs border border-gray-200 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition">关闭</button>
    </div>
  </div>
</div>

<!-- ===== 通知弹窗 ===== -->
<div class="modal-overlay" id="notif-modal">
  <div class="modal-content p-5" style="max-width:480px">
    <div class="flex items-center justify-between mb-3">
      <span class="text-base font-bold">🔔 通知中心</span>
      <div class="flex items-center gap-2">
        <button onclick="openModal('notif-settings-modal')" class="text-gray-400 hover:text-gray-600 text-sm">⚙️</button>
        <button onclick="closeModal('notif-modal')" class="text-gray-400 hover:text-gray-600 text-xl leading-none">×</button>
      </div>
    </div>
    <div class="flex gap-1 mb-3 flex-wrap">
      <span class="ntab active px-2.5 py-1 bg-blue-500 text-white text-[10px] rounded-lg cursor-pointer transition" data-ntab="all">全部</span>
      <span class="ntab px-2.5 py-1 border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 text-[10px] rounded-lg cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 transition" data-ntab="unread">未读</span>
      <span class="ntab px-2.5 py-1 border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 text-[10px] rounded-lg cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 transition" data-ntab="interact">互动</span>
      <span class="ntab px-2.5 py-1 border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 text-[10px] rounded-lg cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 transition" data-ntab="income">收益</span>
      <span class="ntab px-2.5 py-1 border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 text-[10px] rounded-lg cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 transition" data-ntab="system">系统</span>
    </div>
    <div class="border-t border-gray-100 dark:border-gray-700"></div>
    <div class="space-y-2 max-h-72 overflow-y-auto py-2" id="notif-modal-body"></div>
    <div class="text-center mt-2 pt-2 border-t border-gray-100 dark:border-gray-700">
      <button onclick="closeModal('notif-modal');showPage('notifications')" class="text-[11px] text-blue-500 hover:underline">查看全部通知 →</button>
    </div>
  </div>
</div>

<!-- ===== 通知设置弹窗 ===== -->
<div class="modal-overlay" id="notif-settings-modal">
  <div class="modal-content p-5" style="max-width:440px">
    <div class="flex items-center justify-between mb-3">
      <span class="text-base font-bold">⚙️ 通知设置</span>
      <button onclick="closeModal('notif-settings-modal')" class="text-gray-400 hover:text-gray-600 text-xl leading-none">×</button>
    </div>
    <div class="space-y-3">
      <div class="text-xs font-medium mb-2">🔔 通知开关</div>
      <div class="space-y-2">
        <div class="flex items-center justify-between p-2.5 bg-gray-50 dark:bg-gray-700/50 rounded-lg text-xs"><span>系统公告通知</span><label class="flex items-center gap-1 cursor-pointer"><input type="radio" name="n1" checked class="accent-blue-500"> <span>开启</span></label><label class="flex items-center gap-1 cursor-pointer"><input type="radio" name="n1" class="accent-blue-500"> <span>关闭</span></label></div>
        <div class="flex items-center justify-between p-2.5 bg-gray-50 dark:bg-gray-700/50 rounded-lg text-xs"><span>作品互动通知</span><label class="flex items-center gap-1 cursor-pointer"><input type="radio" name="n2" checked class="accent-blue-500"> <span>开启</span></label><label class="flex items-center gap-1 cursor-pointer"><input type="radio" name="n2" class="accent-blue-500"> <span>关闭</span></label></div>
        <div class="flex items-center justify-between p-2.5 bg-gray-50 dark:bg-gray-700/50 rounded-lg text-xs"><span>收益到账通知</span><label class="flex items-center gap-1 cursor-pointer"><input type="radio" name="n3" checked class="accent-blue-500"> <span>开启</span></label><label class="flex items-center gap-1 cursor-pointer"><input type="radio" name="n3" class="accent-blue-500"> <span>关闭</span></label></div>
        <div class="flex items-center justify-between p-2.5 bg-gray-50 dark:bg-gray-700/50 rounded-lg text-xs"><span>活动促销通知</span><label class="flex items-center gap-1 cursor-pointer"><input type="radio" name="n4" checked class="accent-blue-500"> <span>开启</span></label><label class="flex items-center gap-1 cursor-pointer"><input type="radio" name="n4" class="accent-blue-500"> <span>关闭</span></label></div>
      </div>
      <div class="border-t border-gray-100 dark:border-gray-700 pt-3"></div>
      <div class="text-xs font-medium mb-2">📧 邮件通知</div>
      <div class="p-2.5 bg-gray-50 dark:bg-gray-700/50 rounded-lg text-xs space-y-1.5">
        <div class="flex items-center justify-between"><span>接收邮件通知</span><label class="flex items-center gap-1 cursor-pointer"><input type="radio" name="n5" checked class="accent-blue-500"> <span>开启</span></label><label class="flex items-center gap-1 cursor-pointer"><input type="radio" name="n5" class="accent-blue-500"> <span>关闭</span></label></div>
        <div class="flex items-center justify-between"><span>绑定邮箱：user@example.com</span><button onclick="showToast('📧 打开邮箱更换')" class="text-blue-500 hover:underline text-[10px]">更换</button></div>
      </div>
    </div>
    <div class="flex justify-end gap-2 mt-4 pt-3 border-t border-gray-100 dark:border-gray-700">
      <button onclick="closeModal('notif-settings-modal')" class="px-4 py-1.5 text-xs border border-gray-200 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition">取消</button>
      <button onclick="closeModal('notif-settings-modal');showToast('✅ 通知设置已保存')" class="px-4 py-1.5 text-xs bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition">保存设置</button>
    </div>
  </div>
</div>

<!-- ===== 通知详情弹窗 ===== -->
<div class="modal-overlay" id="notif-detail-modal">
  <div class="modal-content p-5" style="max-width:440px">
    <div class="flex items-center justify-between mb-3">
      <span class="text-base font-bold">📋 通知详情</span>
      <button onclick="closeModal('notif-detail-modal')" class="text-gray-400 hover:text-gray-600 text-xl leading-none">×</button>
    </div>
    <div class="space-y-3">
      <div class="flex items-center gap-2"><span class="text-lg">❤️</span><span class="text-xs font-medium text-blue-600">点赞通知</span></div>
      <div class="text-xs text-gray-600 dark:text-gray-400">用户「小明」点赞了你的作品</div>
      <div class="bg-gray-50 dark:bg-gray-700/50 border border-gray-100 dark:border-gray-600 rounded-xl p-3 space-y-1.5 text-xs">
        <div><span class="text-gray-400">作品名称：</span><span class="font-medium">赛博朋克城市夜景</span></div>
        <div><span class="text-gray-400">作品ID：</span>INS_001234</div>
        <div><span class="text-gray-400">点赞时间：</span>2026-05-20 10:30:00</div>
        <div><span class="text-gray-400">当前点赞数：</span>1,234</div>
      </div>
    </div>
    <div class="flex justify-center gap-3 mt-4 pt-3 border-t border-gray-100 dark:border-gray-700">
      <button onclick="closeModal('notif-detail-modal');showToast('🖼️ 跳转作品详情')" class="px-4 py-1.5 text-xs bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition">查看作品</button>
      <button onclick="closeModal('notif-detail-modal');showToast('💬 打开私信窗口')" class="px-4 py-1.5 text-xs border border-gray-200 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition">回复用户</button>
    </div>
  </div>
</div>

<!-- 图片页：提示词优化弹窗 -->
<div id="image-prompt-optimize-modal" class="modal-overlay" aria-hidden="true" onclick="if(event.target===this)closeImagePromptOptimizeModal()">
  <div class="ipom-panel" role="dialog" aria-modal="true" aria-labelledby="ipom-modal-title" onclick="event.stopPropagation()">
    <div class="ipom-head">
      <h3 id="ipom-modal-title">✨ 提示词优化</h3>
    </div>
    <div class="ipom-prompt-wrap">
      <textarea id="ipom-prompt-input" rows="3" placeholder="在此编辑或查看待优化的提示词…"></textarea>
    </div>
    <div class="ipom-body">
      <div class="ipom-schemes" id="ipom-scheme-list"></div>
    </div>
    <div class="ipom-foot">
      <button type="button" class="ipom-cancel-btn" onclick="closeImagePromptOptimizeModal()" aria-label="关闭">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <button type="button" class="ipom-confirm-btn" onclick="confirmImagePromptOptimize()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
      </button>
    </div>
  </div>
</div>

<!-- 视频页：提示词优化弹窗 -->
<div id="video-prompt-optimize-modal" class="modal-overlay" aria-hidden="true" onclick="if(event.target===this)closeVideoPromptOptimizeModal()">
  <div class="ipom-panel" role="dialog" aria-modal="true" aria-labelledby="vpom-modal-title" onclick="event.stopPropagation()">
    <div class="ipom-head">
      <h3 id="vpom-modal-title">✨ 提示词优化</h3>
    </div>
    <div class="ipom-prompt-wrap">
      <textarea id="vpom-prompt-input" rows="3" placeholder="在此编辑或查看待优化的视频描述…"></textarea>
    </div>
    <div class="ipom-body">
      <div class="ipom-schemes" id="vpom-scheme-list"></div>
    </div>
    <div class="ipom-foot">
      <button type="button" class="ipom-cancel-btn" onclick="closeVideoPromptOptimizeModal()" aria-label="关闭">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <button type="button" class="ipom-confirm-btn" onclick="confirmVideoPromptOptimize()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
      </button>
    </div>
  </div>
</div>

<!-- 图片/视频页提示词优化进度 -->
<div id="prompt-optimize-overlay" class="hidden" aria-hidden="true">
  <div class="prompt-optimize-backdrop" aria-hidden="true"></div>
  <div class="prompt-optimize-panel" role="dialog" aria-modal="true" aria-labelledby="prompt-optimize-title">
    <div class="prompt-optimize-icon" aria-hidden="true">✨</div>
    <p class="prompt-optimize-page-tag" id="prompt-optimize-page-tag">图片创作</p>
    <h3 class="prompt-optimize-title" id="prompt-optimize-title">提示词优化中</h3>
    <p class="prompt-optimize-style-name" id="prompt-optimize-style-name">—</p>
    <div class="prompt-optimize-bar-wrap">
      <div id="prompt-optimize-progress-bar" class="prompt-optimize-progress-bar"></div>
    </div>
    <p class="prompt-optimize-status" id="prompt-optimize-status">正在准备...</p>
    <p class="prompt-optimize-hint">AI 正在根据所选风格优化您的创作描述，请稍候</p>
    <p class="prompt-optimize-pct" id="prompt-optimize-pct">0%</p>
  </div>
</div>

<!-- 图片/视频/音频页手机端大弹窗（挂 body） -->
<div id="media-mobile-sheet" class="hidden" aria-hidden="true">
  <div class="media-mobile-sheet-backdrop" onclick="closeMediaMobileSheet()"></div>
  <div class="media-mobile-sheet-panel" role="dialog" aria-modal="true" aria-labelledby="media-sheet-title">
    <div class="media-mobile-sheet-head">
      <h3 id="media-sheet-title">选项</h3>
      <button type="button" class="media-mobile-sheet-close" onclick="closeMediaMobileSheet()" aria-label="关闭">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div id="media-sheet-body"></div>
  </div>
</div>

<!-- 文字页手机端大弹窗（挂 body，避免挡住顶部栏/消息区点击） -->
<div id="chat-mobile-sheet" class="chat-mobile-sheet hidden" aria-hidden="true">
  <div class="chat-mobile-sheet-backdrop" onclick="closeChatMobileSheet()"></div>
  <div class="chat-mobile-sheet-panel" role="dialog" aria-modal="true" aria-labelledby="chat-sheet-title">
    <div class="chat-mobile-sheet-head">
      <h3 id="chat-sheet-title">选项</h3>
      <button type="button" class="chat-mobile-sheet-close" onclick="closeChatMobileSheet()" aria-label="关闭">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div id="chat-sheet-body"></div>
  </div>
</div>

<!-- 多模型协作配置面板（挂到 body，避免挡住聊天消息区点击） -->
<div id="collab-panel" class="hidden fixed inset-0 z-[80] items-center justify-center">
  <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="document.getElementById('collab-panel').classList.add('hidden');"></div>
  <div class="relative bg-white dark:bg-gray-800 border border-purple-200 dark:border-purple-800 rounded-2xl shadow-2xl p-5 w-full max-w-lg mx-4 pointer-events-auto">
    <div class="flex items-center justify-between mb-4">
      <span class="text-sm font-semibold text-purple-700 dark:text-purple-300">⚡ 多模型协作配置</span>
      <button onclick="document.getElementById('collab-panel').classList.add('hidden');" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 w-8 h-8 flex items-center justify-center rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="flex items-center gap-2 mb-3">
      <span class="text-[11px] text-gray-500 shrink-0">🤖 参与模型：</span>
      <select id="collab-new-select" class="flex-1 text-[11px] border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 outline-none">
        <option value="">选择模型...</option>
        <option>GPT-4 Turbo</option>
        <option>Claude 3.5 Sonnet</option>
        <option>DeepSeek V3</option>
        <option>Gemini 2.5 Pro</option>
        <option>Grok 3</option>
        <option>Qwen Max</option>
        <option>Moonshot V1</option>
        <option>ChatGLM-4</option>
      </select>
      <button onclick="addCollabModel()" class="text-[11px] px-3 py-2 bg-purple-500 text-white rounded-lg hover:bg-purple-600">+ 添加</button>
    </div>
    <div id="collab-model-list" class="flex flex-wrap gap-2 mb-4 min-h-[40px]">
      <div class="model-card flex items-center gap-2 px-3 py-2 bg-purple-50 dark:bg-purple-900/20 border border-purple-200 dark:border-purple-800 rounded-lg">
        <input type="checkbox" checked class="accent-purple-500 w-3.5 h-3.5">
        <span class="text-[11px] font-medium">GPT-4 Turbo</span>
        <button class="remove-model text-[9px] text-red-400 hover:text-red-600" onclick="removeCollabModel(this)">✕</button>
      </div>
      <div class="model-card flex items-center gap-2 px-3 py-2 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg">
        <input type="checkbox" checked class="accent-blue-500 w-3.5 h-3.5">
        <span class="text-[11px] font-medium">Claude 3.5 Sonnet</span>
        <button class="remove-model text-[9px] text-red-400 hover:text-red-600" onclick="removeCollabModel(this)">✕</button>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <span class="text-[11px] text-gray-500 shrink-0">✨ 总结模型：</span>
      <select id="collab-summary-select" class="flex-1 text-[11px] border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 outline-none">
        <option>GPT-4 Turbo</option>
        <option>Claude 3.5 Sonnet</option>
      </select>
      <button onclick="startCollab()" class="text-[11px] px-4 py-2 bg-gradient-to-r from-purple-500 to-pink-500 text-white rounded-lg hover:from-purple-600 hover:to-pink-600">开始协作</button>
    </div>
  </div>
</div>
</div>
  <script src="script.js"></script>
<script>
  if (typeof showPage === 'function') showPage('homepage');
</script>
</body>
</html>
