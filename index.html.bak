        </div>
      </div>
    </div>

    <div class="flex justify-end mt-5 pt-4 border-t border-gray-100 dark:border-gray-700">
      <button onclick="closeModal('model-detail-modal')" class="px-5 py-2 text-xs border border-gray-200 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition">关闭</button>
    </div>
  </div>
</div>

<!-- ===== 创建密钥弹窗 ===== -->
<div class="modal-overlay" id="create-key-modal">
  <div class="modal-content p-5" style="max-width:520px">
    <div class="flex items-center justify-between mb-4">
      <span class="text-base font-bold">创建API密钥</span>
      <button onclick="closeModal('create-key-modal')" class="text-gray-400 hover:text-gray-600 text-xl leading-none">×</button>
    </div>

    <div class="space-y-4">
      <!-- 提示 -->
      <div class="flex items-start gap-2 p-3 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg">
        <span class="text-amber-500 text-sm">💡</span>
