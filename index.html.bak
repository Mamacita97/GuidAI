<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,viewport-fit=cover">
<title>GUID.AI - 一站式AI创作平台</title>
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="style.css">
</head>
<body>
<div class="toast" id="toast"></div>

<!-- HEADER NAV (10项: 方案 2.1/19.2节) -->
  <!-- ===== 模块化加载占位 ===== -->
  <div id="app-root">
    <header class="glass border-b border-gray-100 dark:border-gray-800">
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Homepage nav (未登录态) -->
    <div id="nav-home" class="flex items-center justify-between h-14 gap-2 min-w-0">
      <div class="flex items-center gap-2.5 cursor-pointer shrink-0 min-w-0" onclick="showPage('homepage')">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white font-bold text-xs shadow-md shrink-0">G</div>
        <span class="font-bold tracking-tight text-sm truncate">GUID.AI</span>
      </div>
      <nav class="hidden md:flex items-center gap-0.5 flex-1 min-w-0 ml-6">
        <span class="nav-item px-2.5 py-2 text-xs font-medium text-gray-600 dark:text-gray-400 whitespace-nowrap hover:text-blue-500 cursor-pointer" onclick="showPage('inspiration')">✨灵感广场</span>
        <span class="nav-item px-2.5 py-2 text-xs font-medium text-gray-600 dark:text-gray-400 whitespace-nowrap hover:text-blue-500 cursor-pointer" onclick="showPage('model-hub')">🤖模型广场</span>
        <span class="nav-item px-2.5 py-2 text-xs font-medium text-gray-600 dark:text-gray-400 whitespace-nowrap hover:text-blue-500 cursor-pointer" onclick="showPage('chat')">💬文字</span>
        <span class="nav-item px-2.5 py-2 text-xs font-medium text-gray-600 dark:text-gray-400 whitespace-nowrap hover:text-blue-500 cursor-pointer" onclick="showPage('image')">🖼️图片</span>
        <span class="nav-item px-2.5 py-2 text-xs font-medium text-gray-600 dark:text-gray-400 whitespace-nowrap hover:text-blue-500 cursor-pointer" onclick="showPage('video')">🎬视频</span>
        <span class="nav-item px-2.5 py-2 text-xs font-medium text-gray-600 dark:text-gray-400 whitespace-nowrap hover:text-blue-500 cursor-pointer" onclick="showPage('audio')">🎵音频</span>
        <span class="nav-item px-2.5 py-2 text-xs font-medium text-gray-600 dark:text-gray-400 whitespace-nowrap hover:text-blue-500 cursor-pointer" onclick="showPage('3dgs')">3DGS</span>
        <span class="nav-item px-2.5 py-2 text-xs font-medium text-gray-600 dark:text-gray-400 whitespace-nowrap hover:text-blue-500 cursor-pointer" onclick="showPage('apps')">🎮Apps</span>
        <span class="nav-item px-2.5 py-2 text-xs font-medium text-gray-600 dark:text-gray-400 whitespace-nowrap hover:text-blue-500 cursor-pointer" onclick="showPage('myassets')">💎我的产品</span>
        <span class="nav-item px-2.5 py-2 text-xs font-medium text-gray-600 dark:text-gray-400 whitespace-nowrap hover:text-blue-500 cursor-pointer" onclick="showPage('skills')">🔌Skills</span>
      </nav>
      <div class="header-nav-actions flex items-center gap-1 sm:gap-2 shrink-0">
        <button type="button" id="header-menu-btn" class="header-menu-toggle md:hidden" onclick="toggleHeaderMobileMenu()" aria-label="打开菜单" aria-expanded="false">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path class="hm-line hm-line-top" d="M4 6h16"/><path class="hm-line hm-line-mid" d="M4 12h16"/><path class="hm-line hm-line-bot" d="M4 18h16"/></svg>
        </button>
        <div class="relative lang-wrap">
          <button id="lang-btn" class="lang-btn flex items-center gap-1 text-xs text-gray-500 hover:text-gray-800 px-2 py-1 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800">🌐 <span id="current-lang">中文</span> ▼</button>
          <div id="lang-dropdown" class="lang-dropdown hidden absolute right-0 top-full mt-1 w-40 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-lg z-50 overflow-hidden">
            <div class="p-1">
              <div class="lang-option flex items-center gap-2 px-3 py-2 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg cursor-pointer text-xs" data-lang="🇨🇳 简体中文">🇨🇳 简体中文</div>
              <div class="lang-option flex items-center gap-2 px-3 py-2 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg cursor-pointer text-xs" data-lang="🇭🇰 繁體中文">🇭🇰 繁體中文</div>
              <div class="lang-option flex items-center gap-2 px-3 py-2 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg cursor-pointer text-xs" data-lang="🇺🇸 English">🇺🇸 English</div>
              <div class="lang-option flex items-center gap-2 px-3 py-2 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg cursor-pointer text-xs" data-lang="🇯🇵 日本語">🇯🇵 日本語</div>
              <div class="lang-option flex items-center gap-2 px-3 py-2 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg cursor-pointer text-xs" data-lang="🇰🇷 한국어">🇰🇷 한국어</div>
              <div class="lang-option flex items-center gap-2 px-3 py-2 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg cursor-pointer text-xs" data-lang="🇫🇷 Français">🇫🇷 Français</div>
              <div class="lang-option flex items-center gap-2 px-3 py-2 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg cursor-pointer text-xs" data-lang="🇩🇪 Deutsch">🇩🇪 Deutsch</div>
              <div class="lang-option flex items-center gap-2 px-3 py-2 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg cursor-pointer text-xs" data-lang="🇪🇸 Español">🇪🇸 Español</div>
              <div class="lang-option flex items-center gap-2 px-3 py-2 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg cursor-pointer text-xs" data-lang="🇵🇹 Português">🇵🇹 Português</div>
              <div class="lang-option flex items-center gap-2 px-3 py-2 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg cursor-pointer text-xs" data-lang="🇮🇹 Italiano">🇮🇹 Italiano</div>
              <div class="lang-option flex items-center gap-2 px-3 py-2 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg cursor-pointer text-xs" data-lang="🇷🇺 Русский">🇷🇺 Русский</div>
              <div class="lang-option flex items-center gap-2 px-3 py-2 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg cursor-pointer text-xs" data-lang="🇸🇦 العربية">🇸🇦 العربية</div>
              <div class="lang-option flex items-center gap-2 px-3 py-2 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg cursor-pointer text-xs" data-lang="🇮🇳 हिन्दी">🇮🇳 हिन्दी</div>
              <div class="lang-option flex items-center gap-2 px-3 py-2 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg cursor-pointer text-xs" data-lang="🇹🇭 ไทย">🇹🇭 ไทย</div>
              <div class="lang-option flex items-center gap-2 px-3 py-2 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg cursor-pointer text-xs" data-lang="🇻🇳 Tiếng Việt">🇻🇳 Tiếng Việt</div>
            </div>
          </div>
        </div>
        <button class="login-btn px-4 py-1.5 bg-blue-500 text-white text-xs font-semibold rounded-lg hover:bg-blue-600 transition" onclick="openModal('login-modal')">登录</button>
      </div>
    </div>
    <!-- App nav (登录态) -->
    <div id="nav-app" class="flex items-center justify-between h-14 gap-2 min-w-0" style="display:none">
      <div class="flex items-center gap-2.5 shrink-0 min-w-0 cursor-pointer" onclick="showPage('homepage')">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white font-bold text-xs shadow-md shrink-0">G</div>
        <span class="font-bold tracking-tight text-sm truncate">GUID.AI</span>
      </div>
      <nav class="hidden md:flex items-center gap-0.5 flex-1 min-w-0 ml-4">
        <span class="nav-item active px-2.5 py-2 text-xs font-medium whitespace-nowrap cursor-pointer" data-page="inspiration" onclick="showPage(this.dataset.page)">✨灵感广场</span>
        <span class="nav-item px-2.5 py-2 text-xs font-medium text-gray-600 dark:text-gray-400 whitespace-nowrap cursor-pointer" data-page="model-hub" onclick="showPage(this.dataset.page)">🤖模型广场</span>
        <span class="nav-item px-2.5 py-2 text-xs font-medium text-gray-600 dark:text-gray-400 whitespace-nowrap cursor-pointer" data-page="chat" onclick="showPage(this.dataset.page)">💬文字</span>
        <span class="nav-item px-2.5 py-2 text-xs font-medium text-gray-600 dark:text-gray-400 whitespace-nowrap cursor-pointer" data-page="image" onclick="showPage(this.dataset.page)">🖼️图片</span>
        <span class="nav-item px-2.5 py-2 text-xs font-medium text-gray-600 dark:text-gray-400 whitespace-nowrap cursor-pointer" data-page="video" onclick="showPage(this.dataset.page)">🎬视频</span>
        <span class="nav-item px-2.5 py-2 text-xs font-medium text-gray-600 dark:text-gray-400 whitespace-nowrap cursor-pointer" data-page="audio" onclick="showPage(this.dataset.page)">🎵音频</span>
        <span class="nav-item px-2.5 py-2 text-xs font-medium text-gray-600 dark:text-gray-400 whitespace-nowrap cursor-pointer" data-page="3dgs" onclick="showPage(this.dataset.page)">3DGS</span>
        <span class="nav-item px-2.5 py-2 text-xs font-medium text-gray-600 dark:text-gray-400 whitespace-nowrap cursor-pointer" data-page="apps" onclick="showPage(this.dataset.page)">🎮Apps</span>
        <span class="nav-item px-2.5 py-2 text-xs font-medium text-gray-600 dark:text-gray-400 whitespace-nowrap cursor-pointer" data-page="myassets" onclick="showPage(this.dataset.page)">💎我的产品</span>
        <span class="nav-item px-2.5 py-2 text-xs font-medium text-gray-600 dark:text-gray-400 whitespace-nowrap cursor-pointer" data-page="skills" onclick="showPage(this.dataset.page)">🔌Skills</span>
      </nav>
      <div class="header-nav-actions flex items-center gap-1 sm:gap-2 shrink-0">
        <button type="button" id="header-menu-btn-app" class="header-menu-toggle md:hidden" onclick="toggleHeaderMobileMenu()" aria-label="打开菜单" aria-expanded="false">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path class="hm-line hm-line-top" d="M4 6h16"/><path class="hm-line hm-line-mid" d="M4 12h16"/><path class="hm-line hm-line-bot" d="M4 18h16"/></svg>
        </button>
        <div class="flex items-center gap-1 bg-gray-100 dark:bg-gray-800 rounded-full px-2.5 py-1.5 cursor-pointer shrink-0" onclick="pressAnim(this);showPage('wallet');showToast('💰 跳转钱包管理')"><span class="text-yellow-500 text-xs">⚡</span><span class="text-xs font-semibold">12.50</span></div>
        <span class="nav-item hidden sm:inline-flex px-2.5 py-2 text-xs font-medium text-gray-600 dark:text-gray-400 whitespace-nowrap cursor-pointer" data-page="profile" onclick="showPage(this.dataset.page)">👤</span>
      </div>
    </div>
  </div>
</header>

<!-- 顶栏手机端侧滑菜单（未登录 / 已登录共用） -->
<div id="header-mobile-menu" class="header-mobile-menu hidden" aria-hidden="true">
  <div class="header-mobile-menu-backdrop" onclick="closeHeaderMobileMenu()"></div>
  <aside class="header-mobile-menu-panel" role="dialog" aria-modal="true" aria-labelledby="header-mobile-menu-title">
    <div class="header-mobile-menu-head">
      <div class="flex items-center gap-2.5 min-w-0">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white font-bold text-xs shadow-md shrink-0">G</div>
        <span id="header-mobile-menu-title" class="font-bold text-sm truncate">GUID.AI</span>
      </div>
      <button type="button" class="header-mobile-menu-close" onclick="closeHeaderMobileMenu()" aria-label="关闭">&times;</button>
    </div>
    <nav class="header-mobile-menu-body" id="header-mobile-menu-nav" aria-label="主导航"></nav>
    <div class="header-mobile-menu-foot" id="header-mobile-menu-foot"></div>
  </aside>
</div>

<main class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-5">

<!-- ============ PAGE: 官网首页(未登录) - V19.0 Landing Page ============ -->

    <section id="page-homepage" class="page-section active">

  <!-- 1️⃣ 顶部公告滚动条 -->
  <div id="home-announcement-bar" class="home-announcement-bar bg-gradient-to-r from-blue-600 to-blue-700 text-white text-xs overflow-hidden mb-6 rounded-xl">
    <div class="flex items-center h-9">
      <span class="shrink-0 px-4 py-1 bg-white/20 font-semibold whitespace-nowrap flex items-center gap-1.5 text-xs">
        <span>📢</span><span>最新公告</span>
      </span>
      <div class="home-marquee-container flex-1 overflow-hidden relative">
        <div class="home-marquee-content absolute whitespace-nowrap">
          <span class="mx-10 text-xs">🚀 Seedance 2.0 接入新渠道，调用成本下调 30%！</span>
          <span class="mx-4 text-white/40">|</span>
          <span class="mx-10 text-xs">⚡ 新增 Vidu 视频模型，支持 10s 高清生成！</span>
          <span class="mx-4 text-white/40">|</span>
          <span class="mx-10 text-xs">🎉 邀请好友双方各得 100⚡ 平台代币！</span>
        </div>
      </div>
      <button onclick="openModal('announcement-modal')" class="shrink-0 px-4 py-1 bg-white/10 hover:bg-white/20 transition font-medium whitespace-nowrap text-xs">查看详情 →</button>
      <button onclick="closeAnnouncementBar()" class="shrink-0 px-3 py-1 hover:bg-white/20 transition text-white/60 hover:text-white text-xs">✕</button>
    </div>
  </div>

  <!-- 2️⃣ Hero Section -->
  <div class="relative rounded-3xl overflow-hidden mb-10 anim-fade-up" style="background:linear-gradient(135deg,#EFF6FF 0%,#FFFFFF 40%,#F5F3FF 100%);min-height:520px">
    <!-- Decorative blobs -->
    <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-blue-400/[0.07] rounded-full blur-[80px] -translate-y-1/2 pointer-events-none"></div>
    <div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-purple-400/[0.07] rounded-full blur-[80px] translate-y-1/3 pointer-events-none"></div>
    <div class="absolute top-1/3 right-1/6 w-[200px] h-[200px] bg-pink-400/[0.05] rounded-full blur-[60px] pointer-events-none"></div>

    <div class="relative z-10 px-6 py-16 sm:py-20 flex flex-col items-center text-center">
      <!-- Eyebrow badge -->
      <div class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-blue-50 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-800 rounded-full text-xs text-blue-600 dark:text-blue-400 font-medium mb-5">
        <span>🌐</span><span>全球顶尖大模型聚合平台</span>
      </div>

      <!-- Main headline -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight mb-4 leading-tight">
        <span class="hero-text-gradient">GUID.AI</span>
        <span class="text-gray-900 dark:text-white"> — </span>
        <span class="text-gray-800 dark:text-white">全球顶尖大模型聚合平台</span>
      </h1>

      <!-- Sub-headline -->
      <h2 class="text-xl sm:text-2xl font-semibold text-gray-600 dark:text-gray-300 mb-3">
        一个平台，搞定所有 AI 创作
      </h2>

      <!-- Typewriter area -->
      <div class="h-7 mb-6 flex items-center justify-center">
        <span class="text-sm sm:text-base text-gray-500 dark:text-gray-400">告别繁琐的多重订阅 · 一键调用 </span>
        <span id="typewriter-text" class="text-sm sm:text-base font-semibold text-purple-600 dark:text-purple-400 min-w-[12rem] text-left"></span>
        <span class="typewriter-cursor w-0.5 h-5 bg-purple-500 inline-block align-middle ml-0.5"></span>
      </div>

      <!-- Social proof line -->
      <div class="flex items-center gap-4 text-xs text-gray-400 mb-8 flex-wrap justify-center">
        <span class="flex items-center gap-1"><span class="text-yellow-400">⚡</span><span>已服务 <strong class="text-gray-600 dark:text-gray-300">10,000+</strong> 创作者</span></span>
        <span class="text-gray-300 dark:text-gray-600">|</span>
        <span class="flex items-center gap-1"><span>🎨</span><span>生成 <strong class="text-gray-600 dark:text-gray-300">1,000,000+</strong> 优秀作品</span></span>
        <span class="text-gray-300 dark:text-gray-600">|</span>
        <span class="flex items-center gap-1"><span>🌍</span><span>支持 50+ 顶尖模型</span></span>
      </div>

      <!-- CTA buttons -->
      <div class="flex items-center gap-3 flex-wrap justify-center">
        <button onclick="openModal('login-modal')" class="hero-cta-btn px-8 py-3.5 bg-gradient-to-r from-blue-500 to-blue-600 text-white font-bold rounded-xl shadow-lg shadow-blue-500/30 hover:shadow-blue-500/50 hover:-translate-y-0.5 transition-all text-sm flex items-center gap-2">
          <span>👉</span><span>立即开始免费创作</span>
        </button>
        <button onclick="showPage('inspiration')" class="hero-cta-btn px-8 py-3.5 border-2 border-gray-200 dark:border-gray-600 text-gray-700 dark:text-gray-300 font-semibold rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800 hover:-translate-y-0.5 transition-all text-sm flex items-center gap-2">
          <span>🔍</span><span>探索灵感画廊</span>
        </button>
      </div>
    </div>
  </div>

  <!-- 4️⃣ 核心功能：无限可能的创作矩阵 -->
  <div class="mb-10 anim-fade-up stagger-2">
    <div class="text-center mb-7">
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-2">🚀 核心功能</h2>
      <p class="text-sm text-gray-500 dark:text-gray-400">无限可能的创作矩阵 — 5大核心版块</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <!-- ✍️ 智能文字生成 -->
      <div class="feature-v19-card bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 rounded-2xl p-6 group">
        <div class="flex items-center justify-between mb-4">
          <div class="w-12 h-12 rounded-xl bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center text-2xl">✍️</div>
          <span class="text-[10px] px-2 py-1 bg-orange-100 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400 rounded-full font-medium">🔥 热门</span>
        </div>
        <h3 class="text-base font-bold text-gray-900 dark:text-white mb-2">智能文字</h3>
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-4 leading-relaxed">深扒全网爆款密码，一键输出自带流量的带货脚本、小红书爆文，轻松复制10w+</p>
        <div class="flex flex-wrap gap-1.5">
          <span class="text-[10px] px-2 py-1 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 rounded-full">📹 爆款短视频脚本</span>
          <span class="text-[10px] px-2 py-1 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 rounded-full">📕 小红书种草文案</span>
          <span class="text-[10px] px-2 py-1 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 rounded-full">📊 商业BP</span>
        </div>
      </div>

      <!-- 🖼️ 视觉生成 -->
      <div class="feature-v19-card bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 rounded-2xl p-6 group">
        <div class="flex items-center justify-between mb-4">
          <div class="w-12 h-12 rounded-xl bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center text-2xl">🖼️</div>
          <span class="text-[10px] px-2 py-1 bg-orange-100 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400 rounded-full font-medium">🔥 热门</span>
        </div>
        <h3 class="text-base font-bold text-gray-900 dark:text-white mb-2">视觉生成</h3>
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-4 leading-relaxed">低成本打造电商爆款视觉：AI虚拟模特+换装，14图锁定角色一致，出片即爆款</p>
        <div class="flex flex-wrap gap-1.5">
          <span class="text-[10px] px-2 py-1 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 rounded-full">👗 虚拟电商模特</span>
          <span class="text-[10px] px-2 py-1 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 rounded-full">📖 爆款IP绘本</span>
          <span class="text-[10px] px-2 py-1 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 rounded-full">🎨 风格模型出圈</span>
        </div>
      </div>

      <!-- 🎬 视频工坊 -->
      <div class="feature-v19-card bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 rounded-2xl p-6 group">
        <div class="flex items-center justify-between mb-4">
          <div class="w-12 h-12 rounded-xl bg-pink-100 dark:bg-pink-900/30 flex items-center justify-center text-2xl">🎬</div>
          <span class="text-[10px] px-2 py-1 bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400 rounded-full font-medium">✨ 爆款</span>
        </div>
        <h3 class="text-base font-bold text-gray-900 dark:text-white mb-2">视频工坊</h3>
