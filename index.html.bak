            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
            <span id="current-audio-model-text" class="text-gray-600 dark:text-gray-400 font-medium max-w-[120px] truncate">Auto</span>
            <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div id="audio-model-dropdown" class="hidden absolute bottom-full left-0 mb-1 w-56 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-lg overflow-hidden z-50">
            <div class="px-3 py-2 text-[10px] text-gray-400 border-b border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">🎵 音频模型</div>
            <div class="py-1 max-h-48 overflow-y-auto">
              <div onclick="selectAudioModel('Auto','🤖')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer border-b border-gray-100 dark:border-gray-700/80">
                <div class="flex items-center gap-2"><span>🤖</span><div class="flex-1"><div class="flex items-center justify-between gap-2"><span class="text-[11px] font-medium">Auto</span><span class="text-[9px] px-1.5 py-0.5 bg-green-100 dark:bg-green-900/30 text-green-600 rounded shrink-0">推荐</span></div><div class="text-[9px] text-gray-400 mt-0.5">自动选择最优模型</div></div></div>
              </div>
              <div onclick="selectAudioModel('海螺语音克隆 2.8','🐚')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer flex items-center gap-2 text-[11px]"><span>🐚</span><span>海螺语音克隆 2.8</span></div>
              <div onclick="selectAudioModel('ElevenLabs Turbo','🔊')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer flex items-center gap-2 text-[11px]"><span>🔊</span><span>ElevenLabs Turbo</span></div>
              <div onclick="selectAudioModel('Fish Audio','🐟')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer flex items-center gap-2 text-[11px]"><span>🐟</span><span>Fish Audio</span></div>
              <div onclick="selectAudioModel('GPT-4o Voice','🧠')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer flex items-center gap-2 text-[11px]"><span>🧠</span><span>GPT-4o Voice</span></div>
              <div onclick="selectAudioModel('CosmicVoice','🌌')" class="px-3 py-2 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer flex items-center gap-2 text-[11px]"><span>🌌</span><span>CosmicVoice</span></div>
            </div>
          </div>
        </div>
        <!-- 输出参数（语速 / 语调 / 音效） -->
        <div class="relative shrink-0" id="audio-output-params-wrap">
          <button type="button" onclick="toggleAudioOutputParamsDropdown()" class="text-[10px] px-2.5 py-1 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700/50 hover:bg-gray-100 dark:hover:bg-gray-600 transition flex items-center gap-1.5 text-gray-700 dark:text-gray-200">
            <svg class="shrink-0 text-gray-500 dark:text-gray-400" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>
            <span id="audio-output-params-label" class="whitespace-nowrap">1.0x / 标准 / 无</span>
            <svg class="shrink-0 text-gray-400" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div id="audio-output-params-dropdown" class="hidden absolute bottom-full left-0 mb-1 w-[280px] output-params-panel shadow-2xl overflow-hidden z-50">
            <div class="px-3 pt-3 pb-2 border-b border-gray-700/80">
              <div class="vop-section-title">语速</div>
              <div class="flex">
                <button type="button" onclick="setAudioOutputParam('speed','1.0x')" data-aparam="speed" data-avalue="1.0x" class="param-seg-opt">1.0x</button>
                <button type="button" onclick="setAudioOutputParam('speed','0.5x')" data-aparam="speed" data-avalue="0.5x" class="param-seg-opt">0.5x</button>
                <button type="button" onclick="setAudioOutputParam('speed','2.0x')" data-aparam="speed" data-avalue="2.0x" class="param-seg-opt">2.0x</button>
              </div>
            </div>
            <div class="px-3 py-2 border-b border-gray-700/80">
              <div class="vop-section-title">语调</div>
              <div class="flex">
                <button type="button" onclick="setAudioOutputParam('tone','标准')" data-aparam="tone" data-avalue="标准" class="param-seg-opt">标准</button>
                <button type="button" onclick="setAudioOutputParam('tone','柔和')" data-aparam="tone" data-avalue="柔和" class="param-seg-opt">柔和</button>
                <button type="button" onclick="setAudioOutputParam('tone','激昂')" data-aparam="tone" data-avalue="激昂" class="param-seg-opt">激昂</button>
              </div>
            </div>
            <div class="px-3 py-2 pb-3">
              <div class="vop-section-title">音效</div>
              <div class="flex">
                <button type="button" onclick="setAudioOutputParam('effect','无')" data-aparam="effect" data-avalue="无" class="param-seg-opt">无</button>
                <button type="button" onclick="setAudioOutputParam('effect','回声')" data-aparam="effect" data-avalue="回声" class="param-seg-opt">回声</button>
                <button type="button" onclick="setAudioOutputParam('effect','混响')" data-aparam="effect" data-avalue="混响" class="param-seg-opt">混响</button>
              </div>
            </div>
          </div>
          <input type="hidden" id="audio-param-speed" value="1.0x">
          <input type="hidden" id="audio-param-tone" value="标准">
          <input type="hidden" id="audio-param-effect" value="无">
        </div>
        <select id="audio-param-quality" onchange="typeof updateAudioGenCost==='function'&&updateAudioGenCost()" class="text-[10px] border border-gray-200 dark:border-gray-600 rounded-lg px-2 py-1 bg-white dark:bg-gray-800 outline-none shrink-0"><option value="Turbo">质量 Turbo</option><option value="标准">质量 标准</option><option value="高清">质量 高清</option></select>
        <div class="relative shrink-0" id="audio-emotion-wrap">
          <button type="button" id="audio-emotion-btn" onclick="toggleAudioEmotionPicker(event)" class="audio-emotion-btn" title="选择情绪" aria-expanded="false" aria-haspopup="listbox">
            <span id="audio-emotion-btn-emoji" class="audio-emotion-btn-emoji" aria-hidden="true">🎭</span>
            <span class="audio-emotion-btn-text whitespace-nowrap">情绪</span>
          </button>
          <input type="hidden" id="audio-param-emotion" value="">
          <input type="hidden" id="audio-param-emotion-label" value="">
        </div>
        <span id="audio-gen-cost" class="text-[11px] font-medium px-2 py-1 bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-lg border border-blue-100 dark:border-blue-800 shrink-0 whitespace-nowrap inline-flex items-center gap-0.5">💰 本次: <span class="text-yellow-500 leading-none" aria-hidden="true">⚡</span>0.0020</span>
        <div class="flex-1 min-w-[8px]"></div>
        <button type="button" id="audio-gen-btn-desktop" onclick="startAudioGeneration()" class="gen-btn px-4 py-1 bg-gradient-to-r from-blue-500 to-purple-600 text-white text-xs font-semibold rounded-lg hover:from-blue-600 hover:to-purple-700 transition shrink-0">✨ 生成</button>
        </div>
      </div>
    </div>
  </div>
</section>

