      <input id="asset-search" placeholder="🔍 搜索资产..." oninput="filterAssetLibrary()" class="w-full text-xs border border-gray-200 dark:border-gray-600 rounded-lg px-3 py-2 focus:border-blue-500 focus:outline-none bg-white dark:bg-gray-800">
    </div>

