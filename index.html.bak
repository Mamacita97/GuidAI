            <div class="px-3 py-1 text-[10px] text-gray-400 bg-gray-50 dark:bg-gray-800/50">📅 昨天</div>
            <div onclick="loadHistoryChat('chat-4')" class="history-item px-3 py-2 hover:bg-blue-50 dark:hover:bg-blue-900/20 cursor-pointer border-b border-gray-50 dark:border-gray-700/50">
